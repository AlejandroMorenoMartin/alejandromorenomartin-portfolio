---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav        from "@/components/Nav.astro";
import About      from "@/components/sections/About.astro";
import Vision     from "@/components/sections/Vision.astro";
import Craft      from "@/components/sections/Craft.astro";
import Metodo     from "@/components/sections/Metodo.astro";
import Offline    from "@/components/sections/Offline.astro";
import Creditos   from "@/components/sections/Creditos.astro";
import Footer     from "@/components/Footer.astro";
import { useTranslations } from "@/i18n/utils";

const lang = "en" as const;
const t    = useTranslations(lang);

const siteURL = "https://alejandromorenomartin.com";
---

<BaseLayout
  title={`/info · ${t.meta.title}`}
  description={t.meta.description}
  lang={lang}
  tocTitle="/info"
  canonicalURL={`${siteURL}/en/about`}
  alternateURL={`${siteURL}/info`}
  alternateLang="es"
>
  <Nav lang={lang} />
  <main id="main-scroll">
    <About    lang={lang} />
    <Vision   lang={lang} />
    <Metodo   lang={lang} />
    <Craft    lang={lang} />
    <Offline  lang={lang} />
    <Creditos lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
