---
import BaseLayout  from "@/layouts/BaseLayout.astro";
import Nav         from "@/components/Nav.astro";
import Hero        from "@/components/sections/Hero.astro";
import Work        from "@/components/sections/Work.astro";
import About       from "@/components/sections/About.astro";
import Experience  from "@/components/sections/Experience.astro";
import Education   from "@/components/sections/Education.astro";
import Craft       from "@/components/sections/Craft.astro";
import Footer           from "@/components/Footer.astro";
import TableOfContents  from "@/components/TableOfContents.astro";
import { useTranslations } from "@/i18n/utils";

const lang = "en" as const;
const t    = useTranslations(lang);

const siteURL       = "https://alejandromorenomartin.com";
const canonicalURL  = `${siteURL}/en`;
const alternateLang = "es" as const;
const alternateURL  = siteURL;
---

<BaseLayout
  title={t.meta.title}
  description={t.meta.description}
  lang={lang}
  ogImage={t.meta.ogImage}
  canonicalURL={canonicalURL}
  alternateURL={alternateURL}
  alternateLang={alternateLang}
>
  <Nav               lang={lang} />
  <TableOfContents   lang={lang} />
  <main>
    <Hero       lang={lang} />
    <Work       lang={lang} />
    <About      lang={lang} />
    <Experience lang={lang} />
    <Education  lang={lang} />
    <Craft      lang={lang} />
  </main>
  <Footer     lang={lang} />
</BaseLayout>
