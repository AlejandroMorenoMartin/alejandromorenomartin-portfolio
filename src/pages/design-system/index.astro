---
import BaseLayout      from "@/layouts/BaseLayout.astro";
import Nav             from "@/components/Nav.astro";
import Btn             from "@/components/Btn.astro";
import Kpi             from "@/components/Kpi.astro";
import SectionLabel    from "@/components/SectionLabel.astro";
import SubsectionLabel from "@/components/SubsectionLabel.astro";

const lang = "es" as const;
---

<BaseLayout
  title="Design System — Portfolio"
  description="Sistema de diseño interno del portfolio."
  lang={lang}
>
  <Nav lang={lang} />

  <main class="pt-20 pb-48 px-8">
    <div class="container-wide">

      <!-- Header -->
      <div class="mb-20 pb-10 border-b-[0.5px] border-[var(--color-border-subtle)]">
        <p class="text-label-sm text-primary-500 mb-3 tracking-widest uppercase">Portfolio</p>
        <h1 class="font-display text-display-lg font-bold text-text-1 mb-4">Design System</h1>
        <p class="text-body-md text-text-4 max-w-xl">
          Fuente única de verdad. Los tokens se leen de <code class="font-display text-primary-500">global.css</code> en runtime.
          Los componentes son los reales del portfolio.
        </p>
      </div>

      <!-- Sections — filled in subsequent tasks -->
      <!-- ── 1. COLOR ──────────────────────────────────────────────── -->
      <section id="ds-color" class="mb-24" aria-labelledby="color-heading">
        <h2 id="color-heading" class="font-display text-display-lg font-bold text-text-1 mb-12">Color</h2>

        <!-- Primary palette -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Primary — Gold</h3>
        <p class="text-body-md text-text-5 mb-6">Paleta principal. 11 pasos desde casi-blanco hasta casi-negro con tinte dorado.</p>
        <div id="ds-primary-swatches" class="flex flex-wrap gap-2 mb-16"></div>

        <!-- Superficies -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Superficies y bordes</h3>
        <p class="text-body-md text-text-5 mb-6">Fondos semánticos y tokens de borde.</p>
        <div id="ds-surface-swatches" class="flex flex-col gap-3 mb-16"></div>

        <!-- Jerarquía de texto -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Jerarquía de texto</h3>
        <p class="text-body-md text-text-5 mb-6">A mayor tamaño tipográfico → color más puro (text-1). Chrome UI (nav, footer) usa siempre text-5.</p>
        <div id="ds-text-swatches" class="flex flex-col gap-3 mb-16"></div>

        <!-- Gradiente -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Gradiente de texto</h3>
        <p class="text-body-md text-text-5 mb-4">Animado — gold a fucsia-rosa. Clase <code class="font-display text-primary-500">.text-gradient</code>.</p>
        <span class="text-gradient font-display text-display-lg font-bold">Designer</span>
      </section>
      <!-- ── 2. TIPOGRAFÍA ─────────────────────────────────────────── -->
      <section id="ds-typography" class="mb-24" aria-labelledby="type-heading">
        <h2 id="type-heading" class="font-display text-display-lg font-bold text-text-1 mb-12">Tipografía</h2>

        <!-- Font families -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">Familias tipográficas</h3>
        <div class="flex gap-12 mb-16 flex-wrap">
          <div>
            <p class="text-label-xs text-text-6 mb-2 uppercase tracking-widest">font-display / font-body</p>
            <p class="font-display text-display-md text-text-2">Roboto Mono</p>
            <p class="font-display text-body-md text-text-5 mt-1">400 · 500 · 600 · 700</p>
            <p class="font-display text-body-lg text-text-3 mt-3">Aa Bb Cc 0123456789</p>
          </div>
          <div>
            <p class="font-data text-label-xs text-text-6 mb-2 uppercase tracking-widest">font-data</p>
            <p class="font-data text-display-md text-primary-500">Press Start 2P</p>
            <p class="font-data text-label-xs text-text-5 mt-1">400</p>
            <p class="font-data text-body-md text-primary-500 mt-3">+82% €1.2M 3×</p>
          </div>
        </div>

        <!-- Type scale -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Escala tipográfica</h3>
        <p class="text-body-md text-text-5 mb-6">6 tokens. Responsive via CSS vars — mobile (base) → desktop (768px+). El color canónico se aplica automáticamente por clase.</p>
        <div id="ds-type-scale" class="flex flex-col gap-0 mb-16"></div>

        <!-- Visual hierarchy demo -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">Demo de jerarquía visual</h3>
        <div class="p-8 border-[0.5px] border-[var(--color-border-subtle)] bg-surface-raised flex flex-col gap-3 mb-16">
          <p class="font-display text-display-lg font-bold">Título principal — display-lg / text-1</p>
          <p class="font-display text-display-md font-bold">Título de sección — display-md / text-2</p>
          <p class="text-body-lg">Párrafo de introducción — body-lg / text-3</p>
          <p class="text-body-md">Cuerpo principal del contenido — body-md / text-4</p>
          <p class="text-label-sm">Etiqueta de sección o chrome UI — label-sm / text-5</p>
          <p class="text-label-xs">Micro label o tag — label-xs / text-6</p>
        </div>

        <!-- Data typography -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Tipografía de datos</h3>
        <p class="text-body-md text-text-5 mb-6"><code class="font-display text-primary-500">font-data</code> (Press Start 2P) + <code class="font-display text-primary-500">text-primary-500</code>. Solo para KPIs y datos destacados.</p>
        <div class="flex items-baseline gap-8">
          <span class="font-data text-display-md font-bold text-primary-500">+82%</span>
          <span class="font-data text-display-md font-bold text-primary-500">€1.2M</span>
          <span class="font-data text-display-md font-bold text-primary-500">3×</span>
          <code class="font-display text-label-xs text-text-5 ml-4">font-data text-display-md font-bold text-primary-500</code>
        </div>
      </section>
      <!-- ── 3. ESPACIADO Y LAYOUT ─────────────────────────────────── -->
      <section id="ds-spacing" class="mb-24" aria-labelledby="spacing-heading">
        <h2 id="spacing-heading" class="font-display text-display-lg font-bold text-text-1 mb-12">Espaciado y Layout</h2>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Rem base</h3>
        <p class="text-body-md text-text-5 mb-12">
          Sin override — el navegador usa <code class="font-display text-primary-500">16px</code> como base.
          <span class="text-text-6"> · 1rem = 16px · 0.5rem = 8px · 0.25rem = 4px</span>
        </p>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Gap tokens</h3>
        <p class="text-body-md text-text-5 mb-6">Tokens semánticos de espaciado. Se aplican via CSS vars, no valores arbitrarios.</p>
        <div id="ds-gap-tokens" class="flex flex-col gap-4 mb-16"></div>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Contenedores</h3>
        <p class="text-body-md text-text-5 mb-6">Dos anchos máximos. Siempre centrados con <code class="font-display text-primary-500">margin-inline: auto</code>.</p>
        <div class="flex flex-col gap-4 mb-16">
          <div>
            <div class="h-8 bg-surface-overlay border-[0.5px] border-[var(--color-border-subtle)]" style="max-width:640px"></div>
            <p class="text-label-xs text-text-6 mt-1"><code class="font-display text-primary-500">.container-narrow</code> — max-width: 640px</p>
          </div>
          <div>
            <div class="h-8 bg-surface-overlay border-[0.5px] border-[var(--color-border-subtle)]" style="max-width:1024px"></div>
            <p class="text-label-xs text-text-6 mt-1"><code class="font-display text-primary-500">.container-wide</code> — max-width: 1024px</p>
          </div>
        </div>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Patrón de sección</h3>
        <div class="flex flex-col gap-2">
          <code class="font-display text-label-sm text-primary-500">.section-padding</code>
          <p class="text-body-md text-text-5">
            <code class="font-display text-label-xs text-text-4">px-8</code> ·
            <code class="font-display text-label-xs text-text-4">pb-16</code> ·
            <code class="font-display text-label-xs text-text-4">padding-top: var(--page-gap)</code>
          </p>
          <p class="text-body-md text-text-6">Estructura estándar: <code class="font-display text-label-xs">section.section-padding &gt; div.container-wide</code></p>
        </div>
      </section>
      <!-- ── 4. BORDES Y RADIOS ─────────────────────────────────────── -->
      <section id="ds-borders" class="mb-24" aria-labelledby="borders-heading">
        <h2 id="borders-heading" class="font-display text-display-lg font-bold text-text-1 mb-12">Bordes y Radios</h2>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Border radius disponibles</h3>
        <p class="text-body-md text-text-5 mb-2">
          Tokens definidos en <code class="font-display text-primary-500">tailwind.config.ts</code>.
        </p>
        <p class="text-body-md mb-8" style="color:var(--color-primary)">
          Norma del portfolio: <code class="font-display text-label-sm">rounded-none</code> en todos los elementos. Sin excepciones salvo decisión explícita.
        </p>
        <div class="flex flex-wrap gap-6 mb-16">
          {[
            { label: 'none',  value: '0px',    cls: 'rounded-none'  },
            { label: 'sm',    value: '4px',    cls: 'rounded-sm'    },
            { label: 'md',    value: '8px',    cls: 'rounded-md'    },
            { label: 'lg',    value: '12px',   cls: 'rounded-lg'    },
            { label: 'xl',    value: '16px',   cls: 'rounded-xl'    },
            { label: '2xl',   value: '24px',   cls: 'rounded-2xl'   },
            { label: 'full',  value: '9999px', cls: 'rounded-full'  },
          ].map(r => (
            <div class="flex flex-col items-center gap-2">
              <div class={`w-16 h-16 bg-surface-overlay border-[0.5px] border-[var(--color-border)] ${r.cls}`}></div>
              <code class="font-display text-label-xs text-primary-500">{r.label}</code>
              <span class="text-label-xs text-text-7">{r.value}</span>
            </div>
          ))}
        </div>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">Grosor y color de borde</h3>
        <div id="ds-border-styles" class="flex flex-col gap-4"></div>
      </section>
      <!-- ── 5. EFECTOS ────────────────────────────────────────────── -->
      <section id="ds-effects" class="mb-24" aria-labelledby="effects-heading">
        <h2 id="effects-heading" class="font-display text-display-lg font-bold text-text-1 mb-12">Efectos</h2>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Sombras</h3>
        <p class="text-body-md text-text-5 mb-6">Multicapa con tinte dorado. Nunca usar <code class="font-display text-label-xs">shadow-md</code> plana de Tailwind.</p>
        <div id="ds-shadows" class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16"></div>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">Transiciones</h3>
        <div class="flex flex-col gap-4 mb-16">
          {[
            { name: 'fast',   ms: '100ms', use: 'Hover, cambios de color' },
            { name: 'normal', ms: '200ms', use: 'Layout shifts, theme changes' },
            { name: 'slow',   ms: '350ms', use: 'Expansiones, modales' },
          ].map(t => (
            <div class="flex items-center gap-4">
              <code class="font-display text-label-sm text-primary-500 w-16 shrink-0">{t.name}</code>
              <span class="text-label-xs text-text-5 w-16 shrink-0">{t.ms}</span>
              <span class="text-body-md text-text-6">— {t.use}</span>
            </div>
          ))}
        </div>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Background pattern</h3>
        <p class="text-body-md text-text-5 mb-4">Grid dorado sobre fondo oscuro. Definido en <code class="font-display text-primary-500">global.css</code> en el selector <code class="font-display text-label-xs">body</code>.</p>
        <div class="h-32 w-full mb-16 border-[0.5px] border-[var(--color-border-subtle)]" style="background-image: radial-gradient(ellipse 62% 100% at center, var(--color-surface) 5%, transparent 68%), radial-gradient(ellipse at center, transparent 30%, rgba(16,13,7,0.9) 100%), linear-gradient(rgba(228,167,17,0.10) 1px, transparent 1px), linear-gradient(90deg, rgba(228,167,17,0.10) 1px, transparent 1px); background-size: 100% 100%, 100% 100%, 40px 40px, 40px 40px;"></div>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Selección de texto</h3>
        <p class="text-body-md text-text-5 mb-2">Selecciona este texto para ver el highlight gold.</p>
        <p class="text-body-lg text-text-2 mb-12 select-all">← Selecciona esto: background gold rgba(228,167,17,0.25)</p>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Scrollbar</h3>
        <div class="flex gap-3 items-center">
          <div class="overflow-y-scroll h-16 w-48 bg-surface-raised border-[0.5px] border-[var(--color-border-subtle)] p-2">
            <p class="text-body-md text-text-5">Línea 1</p>
            <p class="text-body-md text-text-5">Línea 2</p>
            <p class="text-body-md text-text-5">Línea 3</p>
            <p class="text-body-md text-text-5">Línea 4</p>
            <p class="text-body-md text-text-5">Línea 5</p>
          </div>
          <code class="font-display text-label-xs text-text-6">6px · color-text-7 → text-6 en hover</code>
        </div>
      </section>
      <!-- ── 6. COMPONENTES ────────────────────────────────────────── -->
      <section id="ds-components" class="mb-24" aria-labelledby="components-heading">
        <h2 id="components-heading" class="font-display text-display-lg font-bold text-text-1 mb-12">Componentes</h2>
        <p class="text-body-md text-text-5 mb-16">Todos renderizados con los archivos <code class="font-display text-primary-500">.astro</code> reales del portfolio. Cualquier cambio en el componente se refleja aquí automáticamente.</p>

        <!-- SectionLabel -->
        <div class="mb-16 pb-16 border-b-[0.5px] border-[var(--color-border-subtle)]">
          <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">SectionLabel</h3>
          <SectionLabel label="/experiencia" />
          <code class="font-display text-label-xs text-text-6 block mt-2">&lt;SectionLabel label="/experiencia" /&gt; — label-sm · text-4 · margin-bottom: section-gap</code>
        </div>

        <!-- SubsectionLabel -->
        <div class="mb-16 pb-16 border-b-[0.5px] border-[var(--color-border-subtle)]">
          <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">SubsectionLabel</h3>
          <SubsectionLabel label="Titulaciones" />
          <code class="font-display text-label-xs text-text-6 block mt-2">&lt;SubsectionLabel label="Titulaciones" /&gt; — label-xs · text-5 · margin-bottom: card-gap</code>
        </div>

        <!-- PageTitle -->
        <div class="mb-16 pb-16 border-b-[0.5px] border-[var(--color-border-subtle)]">
          <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">PageTitle</h3>
          <p class="text-body-md text-text-5 mb-6">Etiqueta de título de página. <code class="font-display text-primary-500">text-body-md</code> + <code class="font-display text-primary-500">text-text-3</code> (override via <code class="font-display text-primary-500">#page-title</code> en global.css). El JS del BaseLayout inyecta el texto desde <code class="font-display text-primary-500">data-title</code> al cargar.</p>
          <h1 id="page-title" class="text-body-md" data-title="/work" aria-label="/work">/work</h1>
          <code class="font-display text-label-xs text-text-6 block mt-4">&lt;h1 id="page-title" class="text-body-md" data-title="/work" aria-label="/work"&gt;&lt;/h1&gt;</code>
        </div>

        <!-- Btn states -->
        <div class="mb-16 pb-16 border-b-[0.5px] border-[var(--color-border-subtle)]">
          <h3 class="font-display text-body-lg font-semibold text-text-2 mb-8">Btn</h3>
          <div class="flex flex-col gap-8">
            <div>
              <p class="text-label-xs text-text-7 uppercase tracking-widest mb-3">Idle</p>
              <div class="flex gap-4">
                <Btn>Acción</Btn>
                <Btn href="#">Link</Btn>
              </div>
            </div>
            <div>
              <p class="text-label-xs text-text-7 uppercase tracking-widest mb-3">Hover (simulado)</p>
              <button class="btn" style="color:var(--color-primary);border-color:var(--color-primary)">Acción</button>
            </div>
            <div>
              <p class="text-label-xs text-text-7 uppercase tracking-widest mb-3">Focus-visible (simulado)</p>
              <button class="btn" style="outline:2px solid #E4A711;outline-offset:3px">Acción</button>
            </div>
            <div>
              <p class="text-label-xs text-text-7 uppercase tracking-widest mb-3">Active</p>
              <button class="btn is-active">Acción</button>
            </div>
            <div>
              <p class="text-label-xs text-text-7 uppercase tracking-widest mb-3">Selected — página actual</p>
              <button class="btn" aria-current="page">Acción</button>
            </div>
            <div>
              <p class="text-label-xs text-text-7 uppercase tracking-widest mb-3">Disabled</p>
              <button class="btn" disabled>Acción</button>
            </div>
          </div>
          <code class="font-display text-label-xs text-text-6 mt-8 block">&lt;Btn&gt; — Btn.astro · estilos en global.css</code>
        </div>

        <!-- Kpi -->
        <div class="mb-16 pb-16 border-b-[0.5px] border-[var(--color-border-subtle)]">
          <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">Kpi</h3>
          <p class="text-body-md text-text-5 mb-6">Anima al entrar en viewport (counter 1200ms ease-out). Separadores con divisor 1px.</p>
          <div class="flex items-start gap-8 p-6 bg-surface-raised border-[0.5px] border-[var(--color-border-subtle)]">
            <Kpi value="+82%" label="Task completion" />
            <div class="w-px h-8 self-center bg-[var(--color-border-subtle)]"></div>
            <Kpi value="€1.2M" label="Pipeline growth" />
            <div class="w-px h-8 self-center bg-[var(--color-border-subtle)]"></div>
            <Kpi value="3×" label="Client inquiries" />
          </div>
          <code class="font-display text-label-xs text-text-6 mt-3 block">&lt;Kpi value="+82%" label="Task completion" /&gt;</code>
        </div>

        <!-- Tags -->
        <div class="mb-16 pb-16 border-b-[0.5px] border-[var(--color-border-subtle)]">
          <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">Tag / Pill</h3>
          <p class="text-body-md text-text-5 mb-4">Clase <code class="font-display text-primary-500">.tag</code> — label-xs · text-7 · uppercase. Usado en stacks de proyectos.</p>
          <div class="flex gap-2 flex-wrap">
            {["Astro", "Tailwind CSS", "Figma", "TypeScript", "React Native"].map(tag => (
              <span class="tag bg-surface-overlay border-[0.5px] border-[var(--color-border-subtle)] px-3 py-1">{tag}</span>
            ))}
          </div>
        </div>

        <!-- Links -->
        <div class="mb-16 pb-16 border-b-[0.5px] border-[var(--color-border-subtle)]">
          <h3 class="font-display text-body-lg font-semibold text-text-2 mb-8">Links</h3>

          <p class="text-label-xs text-text-7 uppercase tracking-widest mb-4">link-internal</p>
          <div class="flex gap-8 flex-wrap mb-8">
            <div class="flex flex-col gap-1">
              <a href="#" class="link-internal text-body-md">Alejandro Moreno</a>
              <span class="text-label-xs text-text-7">default</span>
            </div>
            <div class="flex flex-col gap-1">
              <a href="#" class="link-internal text-body-md" style="color:var(--color-text-2)">Alejandro Moreno</a>
              <span class="text-label-xs text-text-7">hover</span>
            </div>
            <div class="flex flex-col gap-1">
              <a href="#" class="link-internal text-body-md" style="outline:2px solid #E4A711;outline-offset:2px">Alejandro Moreno</a>
              <span class="text-label-xs text-text-7">focus-visible</span>
            </div>
          </div>

          <p class="text-label-xs text-text-7 uppercase tracking-widest mb-4">link-external</p>
          <div class="flex gap-8 flex-wrap">
            <div class="flex flex-col gap-1">
              <a href="#" class="link-external text-body-md">Figma</a>
              <span class="text-label-xs text-text-7">default</span>
            </div>
            <div class="flex flex-col gap-1">
              <a href="#" class="link-external text-body-md" style="color:var(--color-text-2)">Figma</a>
              <span class="text-label-xs text-text-7">hover</span>
            </div>
            <div class="flex flex-col gap-1">
              <a href="#" class="link-external text-body-md" style="outline:2px solid #E4A711;outline-offset:2px">Figma</a>
              <span class="text-label-xs text-text-7">focus-visible</span>
            </div>
          </div>
        </div>

        <!-- Card proyecto -->
        <div class="mb-16 pb-16 border-b-[0.5px] border-[var(--color-border-subtle)]">
          <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Card — Proyecto</h3>
          <p class="text-body-md text-text-5 mb-6">Layout horizontal: contenido (flex-1) + imagen (42%). En carousel, una card a la vez. Definida en <code class="font-display text-primary-500">ProjectCard.astro</code>.</p>
          <div class="border-[0.5px] border-[var(--color-border-subtle)] bg-surface overflow-hidden flex flex-col md:flex-row">
            <div class="flex flex-col flex-1 p-8">
              <span class="font-display text-label-sm font-semibold tracking-widest uppercase text-text-5 mb-5 block">Casa del Aire</span>
              <h4 class="font-display text-display-md font-bold text-text-2 leading-[1.1] mb-4">A booking-focused site that cut direct enquiry time by 60%</h4>
              <p class="text-body-md text-text-4 leading-relaxed flex-1 max-w-lg">Designed and developed the full website for a rural house in Extremadura.</p>
              <div class="flex items-start gap-8 mt-8">
                <div><p class="font-data text-display-md font-bold text-primary-500 leading-none">–60%</p><p class="text-label-sm text-text-6 mt-1">Enquiry time</p></div>
                <div class="w-px h-8 self-center bg-[var(--color-border-subtle)]"></div>
                <div><p class="font-data text-display-md font-bold text-primary-500 leading-none">+40%</p><p class="text-label-sm text-text-6 mt-1">Direct bookings</p></div>
              </div>
            </div>
            <div class="md:w-[42%] shrink-0 min-h-[180px] bg-surface-overlay border-t-[0.5px] md:border-t-0 md:border-l-[0.5px] border-[var(--color-border-subtle)] flex items-center justify-center">
              <span class="text-label-xs text-text-7">imagen del proyecto</span>
            </div>
          </div>
        </div>

        <!-- Dots -->
        <div class="mb-16">
          <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">Dots — indicadores</h3>
          <p class="text-body-md text-text-5 mb-6">Patrón unificado en carousel de proyectos y timeline de experiencia.</p>
          <div class="flex flex-col gap-6">
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3">
                <span class="block w-1.5 h-1.5 rounded-none bg-text-8"></span>
                <span class="block w-1.5 h-1.5 rounded-none bg-text-8"></span>
                <span class="block w-2 h-2 rounded-none" style="background:#E4A711;box-shadow:0 0 0 3px rgba(228,167,17,0.2)"></span>
                <span class="block w-1.5 h-1.5 rounded-none bg-text-8"></span>
              </div>
              <code class="font-display text-label-xs text-text-6">Carousel: 6×6 bg-text-8 — activo: 8×8 gold + glow ring</code>
            </div>
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3">
                <span class="block w-3.5 h-3.5 rounded-none bg-text-8 border-[0.5px] border-[var(--color-border-subtle)]"></span>
                <span class="block w-3.5 h-3.5 rounded-none" style="background:#E4A711;box-shadow:0 0 0 3px rgba(228,167,17,0.2)"></span>
              </div>
              <code class="font-display text-label-xs text-text-6">Timeline: 3.5px — activo gold + glow</code>
            </div>
          </div>
        </div>
      </section>

    </div>
  </main>
</BaseLayout>

<script>
  // Dev-only gate: redirect to / in production (output:static, no server-side redirect)
  const host = window.location.hostname;
  if (host !== 'localhost' && host !== '127.0.0.1') {
    window.location.replace('/');
  }
</script>

<script>
  // ── Design System — Token reader ─────────────────────────────
  const style = getComputedStyle(document.documentElement);

  // Primary palette (11 steps)
  const primarySteps = [50,100,200,300,400,500,600,700,800,900,950];
  const primaryContainer = document.getElementById('ds-primary-swatches');
  if (primaryContainer) {
    primaryContainer.innerHTML = primarySteps.map(n => {
      const val = style.getPropertyValue(`--color-primary-${n}`).trim();
      return `
        <div class="flex flex-col items-center gap-1.5">
          <div style="width:3rem;height:3rem;background:${val};border:0.5px solid rgba(255,255,255,0.08)"></div>
          <span style="font-family:'Roboto Mono',monospace;font-size:10px;color:var(--color-text-6)">${n}</span>
          <span style="font-family:'Roboto Mono',monospace;font-size:9px;color:var(--color-text-7)">${val}</span>
        </div>`;
    }).join('');
  }

  // Surfaces & borders
  const surfaces = [
    { token: '--color-surface',         label: 'surface',         desc: 'Fondo base' },
    { token: '--color-surface-raised',  label: 'surface-raised',  desc: 'Fondo elevado' },
    { token: '--color-surface-overlay', label: 'surface-overlay', desc: 'Fondo overlay / icon bg' },
    { token: '--color-border',          label: 'border',          desc: 'Borde estándar' },
    { token: '--color-border-strong',   label: 'border-strong',   desc: 'Borde reforzado' },
  ];
  const surfaceContainer = document.getElementById('ds-surface-swatches');
  if (surfaceContainer) {
    surfaceContainer.innerHTML = surfaces.map(s => {
      const val = style.getPropertyValue(s.token).trim();
      return `
        <div style="display:flex;align-items:center;gap:1rem">
          <div style="width:1.5rem;height:1.5rem;background:${val};border:0.5px solid rgba(255,255,255,0.15);flex-shrink:0"></div>
          <code style="font-family:'Roboto Mono',monospace;font-size:11px;color:var(--color-primary);width:11rem;flex-shrink:0">${s.label}</code>
          <span style="font-family:'Roboto Mono',monospace;font-size:10px;color:var(--color-text-6);width:6rem;flex-shrink:0">${val}</span>
          <span style="font-size:14px;color:var(--color-text-5)">${s.desc}</span>
        </div>`;
    }).join('');
  }

  // Text hierarchy tokens
  const textTokens = [
    { token: '--color-text-1', label: 'text-1', desc: 'Títulos principales (display-lg)' },
    { token: '--color-text-2', label: 'text-2', desc: 'Títulos secundarios (display-md)' },
    { token: '--color-text-3', label: 'text-3', desc: 'Cuerpo grande (body-lg)' },
    { token: '--color-text-4', label: 'text-4', desc: 'Cuerpo principal (body-md)' },
    { token: '--color-text-5', label: 'text-5', desc: 'Labels, nav, footer, chrome UI (label-sm)' },
    { token: '--color-text-6', label: 'text-6', desc: 'Micro labels, subsecciones (label-xs)' },
    { token: '--color-text-7', label: 'text-7', desc: 'Tags, placeholder' },
    { token: '--color-text-8', label: 'text-8', desc: 'Disabled, decorativo mínimo' },
  ];
  const textContainer = document.getElementById('ds-text-swatches');
  if (textContainer) {
    textContainer.innerHTML = textTokens.map(t => {
      const val = style.getPropertyValue(t.token).trim();
      return `
        <div style="display:flex;align-items:center;gap:1rem">
          <div style="width:1.5rem;height:1.5rem;border-radius:0;background:${val};flex-shrink:0"></div>
          <code style="font-family:'Roboto Mono',monospace;font-size:11px;color:var(--color-primary);width:5rem;flex-shrink:0">${t.label}</code>
          <span style="font-family:'Roboto Mono',monospace;font-size:10px;color:var(--color-text-6);width:6rem;flex-shrink:0">${val}</span>
          <span style="font-size:14px;color:${val};flex:1">${t.desc}</span>
        </div>`;
    }).join('');
  }

  // ── Typography section ───────────────────────────────────────
  const typeTokens = [
    { token: '--fs-display-lg', name: 'display-lg', lh: '1.2',  color: 'text-1', use: 'Título principal' },
    { token: '--fs-display-md', name: 'display-md', lh: '1.25', color: 'text-2', use: 'Título de sección' },
    { token: '--fs-body-lg',    name: 'body-lg',    lh: '1.6',  color: 'text-3', use: 'Cuerpo grande, intro' },
    { token: '--fs-body-md',    name: 'body-md',    lh: '1.65', color: 'text-4', use: 'Cuerpo principal' },
    { token: '--fs-label-sm',   name: 'label-sm',   lh: '1.5',  color: 'text-5', use: 'Labels, nav, footer' },
    { token: '--fs-label-xs',   name: 'label-xs',   lh: '1.4',  color: 'text-6', use: 'Micro labels, tags' },
  ];
  const typeContainer = document.getElementById('ds-type-scale');
  if (typeContainer) {
    typeContainer.innerHTML = typeTokens.map(t => {
      const fs = style.getPropertyValue(t.token).trim();
      const colorVal = style.getPropertyValue(`--color-${t.color}`).trim();
      return `
        <div style="display:flex;align-items:baseline;gap:1.5rem;padding:0.75rem 0;border-bottom:0.5px solid var(--color-border-subtle)">
          <code style="font-family:'Roboto Mono',monospace;font-size:11px;color:var(--color-primary);width:7rem;flex-shrink:0">${t.name}</code>
          <span style="font-family:'Roboto Mono',monospace;font-size:10px;color:var(--color-text-6);width:3.5rem;flex-shrink:0">${fs}</span>
          <span style="font-family:'Roboto Mono',monospace;font-size:10px;color:var(--color-text-7);width:2rem;flex-shrink:0">${t.lh}</span>
          <span style="font-size:${fs};color:${colorVal};line-height:1;flex-shrink:0">Aa</span>
          <span style="font-size:13px;color:var(--color-text-5);margin-left:auto">${t.use}</span>
        </div>`;
    }).join('');
  }

  // ── Spacing section ──────────────────────────────────────────
  const gapTokens = [
    { token: '--page-gap',    label: 'page-gap',    desc: 'Padding top de cada sección de página' },
    { token: '--section-gap', label: 'section-gap', desc: 'Margen bottom de SectionLabel' },
    { token: '--card-gap',    label: 'card-gap',    desc: 'Margen bottom de SubsectionLabel' },
  ];
  const gapContainer = document.getElementById('ds-gap-tokens');
  if (gapContainer) {
    gapContainer.innerHTML = gapTokens.map(g => {
      const val = style.getPropertyValue(g.token).trim();
      const px = parseFloat(val) * 16;
      return `
        <div style="display:flex;align-items:center;gap:1rem">
          <div style="height:1rem;background:var(--color-primary);opacity:0.3;width:${px}px;flex-shrink:0;min-width:4px"></div>
          <code style="font-family:'Roboto Mono',monospace;font-size:11px;color:var(--color-primary);width:8rem;flex-shrink:0">${g.label}</code>
          <span style="font-family:'Roboto Mono',monospace;font-size:10px;color:var(--color-text-6);width:9rem;flex-shrink:0">${val} (${px}px)</span>
          <span style="font-size:13px;color:var(--color-text-5)">${g.desc}</span>
        </div>`;
    }).join('');
  }

  // ── Borders section ──────────────────────────────────────────
  const borderStyles = [
    { label: '0.5px estándar', thick: '0.5px', tokenName: '--color-border-subtle', desc: 'Cards, separadores, layout' },
    { label: '1px fuerte',     thick: '1px',   tokenName: '--color-border-strong', desc: 'Btn, elementos interactivos' },
  ];
  const borderContainer = document.getElementById('ds-border-styles');
  if (borderContainer) {
    borderContainer.innerHTML = borderStyles.map(b => {
      const colorVal = style.getPropertyValue(b.tokenName).trim();
      return `
        <div style="display:flex;align-items:center;gap:1.5rem">
          <div style="width:6rem;height:2.5rem;border:${b.thick} solid ${colorVal || 'var(--color-border)'};flex-shrink:0"></div>
          <code style="font-family:'Roboto Mono',monospace;font-size:11px;color:var(--color-primary);width:9rem;flex-shrink:0">${b.label}</code>
          <span style="font-size:13px;color:var(--color-text-5)">${b.desc}</span>
        </div>`;
    }).join('');
  }

  // ── Effects section ──────────────────────────────────────────
  const shadows = [
    { token: '--shadow-sm',   label: 'ds-sm',   desc: 'Cards en reposo' },
    { token: '--shadow-md',   label: 'ds-md',   desc: 'Hover, modales' },
    { token: '--shadow-lg',   label: 'ds-lg',   desc: 'Dropdowns, popovers' },
    { token: '--shadow-glow', label: 'ds-glow', desc: 'Focus ring dorado' },
  ];
  const shadowContainer = document.getElementById('ds-shadows');
  if (shadowContainer) {
    shadowContainer.innerHTML = shadows.map(s => {
      const val = style.getPropertyValue(s.token).trim();
      return `
        <div style="padding:1.5rem;background:var(--color-surface-raised);box-shadow:${val}">
          <code style="font-family:'Roboto Mono',monospace;font-size:11px;color:var(--color-primary);display:block;margin-bottom:0.25rem">${s.label}</code>
          <span style="font-size:13px;color:var(--color-text-5)">${s.desc}</span>
        </div>`;
    }).join('');
  }
</script>
