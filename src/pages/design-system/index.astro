---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav        from "@/components/Nav.astro";

const lang = "es" as const;
---

<BaseLayout
  title="Design System — Portfolio"
  description="Sistema de diseño interno del portfolio."
  lang={lang}
>
  <Nav lang={lang} />

  <main class="pt-20 pb-48 px-8">
    <div class="container-wide">

      <!-- Header -->
      <div class="mb-20 pb-10 border-b-[0.5px] border-[var(--color-border-subtle)]">
        <p class="font-data text-label-sm text-primary-500 mb-3 tracking-widest uppercase">Portfolio</p>
        <h1 class="font-display text-display-lg font-bold text-text-1 mb-4">Design System</h1>
        <p class="text-body-md text-text-4 max-w-xl">
          Fuente única de verdad. Los tokens se leen de <code class="font-data text-primary-500">global.css</code> en runtime.
          Los componentes son los reales del portfolio.
        </p>
      </div>

      <!-- Sections — filled in subsequent tasks -->
      <!-- ── 1. COLOR ──────────────────────────────────────────────── -->
      <section id="ds-color" class="mb-24" aria-labelledby="color-heading">
        <h2 id="color-heading" class="font-display text-display-lg font-bold text-text-1 mb-12">Color</h2>

        <!-- Primary palette -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Primary — Gold</h3>
        <p class="text-body-md text-text-5 mb-6">Paleta principal. 11 pasos desde casi-blanco hasta casi-negro con tinte dorado.</p>
        <div id="ds-primary-swatches" class="flex flex-wrap gap-2 mb-16"></div>

        <!-- Superficies -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Superficies y bordes</h3>
        <p class="text-body-md text-text-5 mb-6">Fondos semánticos y tokens de borde.</p>
        <div id="ds-surface-swatches" class="flex flex-col gap-3 mb-16"></div>

        <!-- Jerarquía de texto -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Jerarquía de texto</h3>
        <p class="text-body-md text-text-5 mb-6">A mayor tamaño tipográfico → color más puro (text-1). Chrome UI (nav, footer) usa siempre text-5.</p>
        <div id="ds-text-swatches" class="flex flex-col gap-3 mb-16"></div>

        <!-- Gradiente -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Gradiente de texto</h3>
        <p class="text-body-md text-text-5 mb-4">Animado — gold a fucsia-rosa. Clase <code class="font-data text-primary-500">.text-gradient</code>.</p>
        <span class="text-gradient font-display text-display-lg font-bold">Designer</span>
      </section>
      <!-- ── 2. TIPOGRAFÍA ─────────────────────────────────────────── -->
      <section id="ds-typography" class="mb-24" aria-labelledby="type-heading">
        <h2 id="type-heading" class="font-display text-display-lg font-bold text-text-1 mb-12">Tipografía</h2>

        <!-- Font families -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">Familias tipográficas</h3>
        <div class="flex gap-12 mb-16 flex-wrap">
          <div>
            <p class="font-data text-label-xs text-text-6 mb-2 uppercase tracking-widest">font-display / font-body</p>
            <p class="font-display text-display-md text-text-2">Roboto Mono</p>
            <p class="font-display text-body-md text-text-5 mt-1">400 · 500 · 600 · 700</p>
            <p class="font-display text-body-lg text-text-3 mt-3">Aa Bb Cc 0123456789</p>
          </div>
          <div>
            <p class="font-data text-label-xs text-text-6 mb-2 uppercase tracking-widest">font-data</p>
            <p class="font-data text-display-md text-primary-500">Press Start 2P</p>
            <p class="font-data text-label-xs text-text-5 mt-1">400</p>
            <p class="font-data text-body-md text-primary-500 mt-3">+82% €1.2M 3×</p>
          </div>
        </div>

        <!-- Type scale -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-2">Escala tipográfica</h3>
        <p class="text-body-md text-text-5 mb-6">6 tokens. Responsive via CSS vars — mobile (base) → desktop (768px+). El color canónico se aplica automáticamente por clase.</p>
        <div id="ds-type-scale" class="flex flex-col gap-0 mb-16"></div>

        <!-- Visual hierarchy demo -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-6">Demo de jerarquía visual</h3>
        <div class="p-8 border-[0.5px] border-[var(--color-border-subtle)] bg-surface-raised flex flex-col gap-3 mb-16">
          <p class="font-display text-display-lg font-bold">Título principal — display-lg / text-1</p>
          <p class="font-display text-display-md font-bold">Título de sección — display-md / text-2</p>
          <p class="text-body-lg">Párrafo de introducción — body-lg / text-3</p>
          <p class="text-body-md">Cuerpo principal del contenido — body-md / text-4</p>
          <p class="text-label-sm">Etiqueta de sección o chrome UI — label-sm / text-5</p>
          <p class="text-label-xs">Micro label o tag — label-xs / text-6</p>
        </div>

        <!-- Data typography -->
        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Tipografía de datos</h3>
        <p class="text-body-md text-text-5 mb-6"><code class="font-data text-primary-500">font-data</code> (Press Start 2P) + <code class="font-data text-primary-500">text-primary-500</code>. Solo para KPIs y datos destacados.</p>
        <div class="flex items-baseline gap-8">
          <span class="font-data text-display-md font-bold text-primary-500">+82%</span>
          <span class="font-data text-display-md font-bold text-primary-500">€1.2M</span>
          <span class="font-data text-display-md font-bold text-primary-500">3×</span>
          <code class="font-data text-label-xs text-text-5 ml-4">font-data text-display-md font-bold text-primary-500</code>
        </div>
      </section>
      <!-- ── 3. ESPACIADO Y LAYOUT ─────────────────────────────────── -->
      <section id="ds-spacing" class="mb-24" aria-labelledby="spacing-heading">
        <h2 id="spacing-heading" class="font-display text-display-lg font-bold text-text-1 mb-12">Espaciado y Layout</h2>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Rem base</h3>
        <p class="text-body-md text-text-5 mb-12">
          Sin override — el navegador usa <code class="font-data text-primary-500">16px</code> como base.
          <span class="text-text-6"> · 1rem = 16px · 0.5rem = 8px · 0.25rem = 4px</span>
        </p>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Gap tokens</h3>
        <p class="text-body-md text-text-5 mb-6">Tokens semánticos de espaciado. Se aplican via CSS vars, no valores arbitrarios.</p>
        <div id="ds-gap-tokens" class="flex flex-col gap-4 mb-16"></div>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Contenedores</h3>
        <p class="text-body-md text-text-5 mb-6">Dos anchos máximos. Siempre centrados con <code class="font-data text-primary-500">margin-inline: auto</code>.</p>
        <div class="flex flex-col gap-4 mb-16">
          <div>
            <div class="h-8 bg-surface-overlay border-[0.5px] border-[var(--color-border-subtle)]" style="max-width:640px"></div>
            <p class="text-label-xs text-text-6 mt-1"><code class="font-data text-primary-500">.container-narrow</code> — max-width: 640px</p>
          </div>
          <div>
            <div class="h-8 bg-surface-overlay border-[0.5px] border-[var(--color-border-subtle)]" style="max-width:1024px"></div>
            <p class="text-label-xs text-text-6 mt-1"><code class="font-data text-primary-500">.container-wide</code> — max-width: 1024px</p>
          </div>
        </div>

        <h3 class="font-display text-body-lg font-semibold text-text-2 mb-4">Patrón de sección</h3>
        <div class="flex flex-col gap-2">
          <code class="font-data text-label-sm text-primary-500">.section-padding</code>
          <p class="text-body-md text-text-5">
            <code class="font-data text-label-xs text-text-4">px-8</code> ·
            <code class="font-data text-label-xs text-text-4">pb-16</code> ·
            <code class="font-data text-label-xs text-text-4">padding-top: var(--page-gap)</code>
          </p>
          <p class="text-body-md text-text-6">Estructura estándar: <code class="font-data text-label-xs">section.section-padding &gt; div.container-wide</code></p>
        </div>
      </section>
      <div id="ds-borders"    class="mb-24"></div>
      <div id="ds-effects"    class="mb-24"></div>
      <div id="ds-components" class="mb-24"></div>

    </div>
  </main>
</BaseLayout>

<script>
  // Dev-only gate: redirect to / in production (output:static, no server-side redirect)
  const host = window.location.hostname;
  if (host !== 'localhost' && host !== '127.0.0.1') {
    window.location.replace('/');
  }
</script>

<script>
  // ── Design System — Token reader ─────────────────────────────
  const style = getComputedStyle(document.documentElement);

  // Primary palette (11 steps)
  const primarySteps = [50,100,200,300,400,500,600,700,800,900,950];
  const primaryContainer = document.getElementById('ds-primary-swatches');
  if (primaryContainer) {
    primaryContainer.innerHTML = primarySteps.map(n => {
      const val = style.getPropertyValue(`--color-primary-${n}`).trim();
      return `
        <div class="flex flex-col items-center gap-1.5">
          <div style="width:3rem;height:3rem;background:${val};border:0.5px solid rgba(255,255,255,0.08)"></div>
          <span class="font-data" style="font-size:10px;color:var(--color-text-6)">${n}</span>
          <span class="font-data" style="font-size:9px;color:var(--color-text-7)">${val}</span>
        </div>`;
    }).join('');
  }

  // Surfaces & borders
  const surfaces = [
    { token: '--color-surface',         label: 'surface',         desc: 'Fondo base' },
    { token: '--color-surface-raised',  label: 'surface-raised',  desc: 'Fondo elevado' },
    { token: '--color-surface-overlay', label: 'surface-overlay', desc: 'Fondo overlay / icon bg' },
    { token: '--color-border',          label: 'border',          desc: 'Borde estándar' },
    { token: '--color-border-strong',   label: 'border-strong',   desc: 'Borde reforzado' },
  ];
  const surfaceContainer = document.getElementById('ds-surface-swatches');
  if (surfaceContainer) {
    surfaceContainer.innerHTML = surfaces.map(s => {
      const val = style.getPropertyValue(s.token).trim();
      return `
        <div style="display:flex;align-items:center;gap:1rem">
          <div style="width:1.5rem;height:1.5rem;background:${val};border:0.5px solid rgba(255,255,255,0.15);flex-shrink:0"></div>
          <code style="font-family:'Press Start 2P',monospace;font-size:11px;color:var(--color-primary);width:11rem;flex-shrink:0">${s.label}</code>
          <span style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--color-text-6);width:6rem;flex-shrink:0">${val}</span>
          <span style="font-size:14px;color:var(--color-text-5)">${s.desc}</span>
        </div>`;
    }).join('');
  }

  // Text hierarchy tokens
  const textTokens = [
    { token: '--color-text-1', label: 'text-1', desc: 'Títulos principales (display-lg)' },
    { token: '--color-text-2', label: 'text-2', desc: 'Títulos secundarios (display-md)' },
    { token: '--color-text-3', label: 'text-3', desc: 'Cuerpo grande (body-lg)' },
    { token: '--color-text-4', label: 'text-4', desc: 'Cuerpo principal (body-md)' },
    { token: '--color-text-5', label: 'text-5', desc: 'Labels, nav, footer, chrome UI (label-sm)' },
    { token: '--color-text-6', label: 'text-6', desc: 'Micro labels, subsecciones (label-xs)' },
    { token: '--color-text-7', label: 'text-7', desc: 'Tags, placeholder' },
    { token: '--color-text-8', label: 'text-8', desc: 'Disabled, decorativo mínimo' },
  ];
  const textContainer = document.getElementById('ds-text-swatches');
  if (textContainer) {
    textContainer.innerHTML = textTokens.map(t => {
      const val = style.getPropertyValue(t.token).trim();
      return `
        <div style="display:flex;align-items:center;gap:1rem">
          <div style="width:1.5rem;height:1.5rem;border-radius:50%;background:${val};flex-shrink:0"></div>
          <code style="font-family:'Press Start 2P',monospace;font-size:11px;color:var(--color-primary);width:5rem;flex-shrink:0">${t.label}</code>
          <span style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--color-text-6);width:6rem;flex-shrink:0">${val}</span>
          <span style="font-size:14px;color:${val};flex:1">${t.desc}</span>
        </div>`;
    }).join('');
  }

  // ── Typography section ───────────────────────────────────────
  const typeTokens = [
    { token: '--fs-display-lg', name: 'display-lg', lh: '1.2',  color: 'text-1', use: 'Título principal' },
    { token: '--fs-display-md', name: 'display-md', lh: '1.25', color: 'text-2', use: 'Título de sección' },
    { token: '--fs-body-lg',    name: 'body-lg',    lh: '1.6',  color: 'text-3', use: 'Cuerpo grande, intro' },
    { token: '--fs-body-md',    name: 'body-md',    lh: '1.65', color: 'text-4', use: 'Cuerpo principal' },
    { token: '--fs-label-sm',   name: 'label-sm',   lh: '1.5',  color: 'text-5', use: 'Labels, nav, footer' },
    { token: '--fs-label-xs',   name: 'label-xs',   lh: '1.4',  color: 'text-6', use: 'Micro labels, tags' },
  ];
  const typeContainer = document.getElementById('ds-type-scale');
  if (typeContainer) {
    typeContainer.innerHTML = typeTokens.map(t => {
      const fs = style.getPropertyValue(t.token).trim();
      const colorVal = style.getPropertyValue(`--color-${t.color}`).trim();
      return `
        <div style="display:flex;align-items:baseline;gap:1.5rem;padding:0.75rem 0;border-bottom:0.5px solid var(--color-border-subtle)">
          <code style="font-family:'Press Start 2P',monospace;font-size:11px;color:var(--color-primary);width:7rem;flex-shrink:0">${t.name}</code>
          <span style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--color-text-6);width:3.5rem;flex-shrink:0">${fs}</span>
          <span style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--color-text-7);width:2rem;flex-shrink:0">${t.lh}</span>
          <span style="font-size:${fs};color:${colorVal};line-height:1;flex-shrink:0">Aa</span>
          <span style="font-size:13px;color:var(--color-text-5);margin-left:auto">${t.use}</span>
        </div>`;
    }).join('');
  }

  // ── Spacing section ──────────────────────────────────────────
  const gapTokens = [
    { token: '--page-gap',    label: 'page-gap',    desc: 'Padding top de cada sección de página' },
    { token: '--section-gap', label: 'section-gap', desc: 'Margen bottom de SectionLabel' },
    { token: '--card-gap',    label: 'card-gap',    desc: 'Margen bottom de SubsectionLabel' },
  ];
  const gapContainer = document.getElementById('ds-gap-tokens');
  if (gapContainer) {
    gapContainer.innerHTML = gapTokens.map(g => {
      const val = style.getPropertyValue(g.token).trim();
      const px = parseFloat(val) * 16;
      return `
        <div style="display:flex;align-items:center;gap:1rem">
          <div style="height:1rem;background:var(--color-primary);opacity:0.3;width:${px}px;flex-shrink:0;min-width:4px"></div>
          <code style="font-family:'Press Start 2P',monospace;font-size:11px;color:var(--color-primary);width:8rem;flex-shrink:0">${g.label}</code>
          <span style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--color-text-6);width:9rem;flex-shrink:0">${val} (${px}px)</span>
          <span style="font-size:13px;color:var(--color-text-5)">${g.desc}</span>
        </div>`;
    }).join('');
  }
</script>
