---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav        from "@/components/Nav.astro";

const lang = "es" as const;

// Token reference data — single source of truth aligned with global.css + tailwind.config.ts
const textTokens = [
  { token: "text-1", hex_dark: "#ffffff", hex_light: "#0a0a0a", use: "H1 hero, headings principales" },
  { token: "text-2", hex_dark: "#e8e8e8", hex_light: "#1f1f1f", use: "H2 — section headings" },
  { token: "text-3", hex_dark: "#c8c8c8", hex_light: "#3d3d3d", use: "H3 — card headlines, subtítulos" },
  { token: "text-4", hex_dark: "#a8a8a8", hex_light: "#5c5c5c", use: "Body principal, descripciones" },
  { token: "text-5", hex_dark: "#909090", hex_light: "#757575", use: "Nav, footer, labels UI, meta — color estándar de chrome" },
  { token: "text-6", hex_dark: "#787878", hex_light: "#8f8f8f", use: "Body secundario, subtexto de apoyo" },
  { token: "text-7", hex_dark: "#606060", hex_light: "#a3a3a3", use: "Placeholder, elementos inactivos" },
  { token: "text-8", hex_dark: "#505050", hex_light: "#b8b8b8", use: "Disabled, decorativo mínimo" },
];

const surfaceTokens = [
  { token: "surface",         dark: "#0f0e0c", light: "#ffffff",  label: "Fondo base" },
  { token: "surface-raised",  dark: "#1a1813", light: "#f8f6f2",  label: "Fondo elevado" },
  { token: "surface-overlay", dark: "#242019", light: "#f0ece4",  label: "Fondo overlay / icon bg" },
  { token: "border",          dark: "#2a2620", light: "#e8e3d8",  label: "Borde estándar" },
  { token: "border-strong",   dark: "#3d3828", light: "#d4ccba",  label: "Borde reforzado" },
];

// Responsive via CSS vars — mobile → desktop (768px+)
const typoScale = [
  { token: "display-lg", mobile: "26px", desktop: "30px", lh: "1.2",  ls: "—",      color: "text-text-1", use: "Título principal" },
  { token: "display-md", mobile: "20px", desktop: "22px", lh: "1.25", ls: "—",      color: "text-text-2", use: "Título secundario" },
  { token: "body-lg",    mobile: "16px", desktop: "18px", lh: "1.6",  ls: "—",      color: "text-text-3", use: "Cuerpo grande, introducción" },
  { token: "body-md",    mobile: "14px", desktop: "16px", lh: "1.65", ls: "—",      color: "text-text-4", use: "Cuerpo principal" },
  { token: "label-sm",   mobile: "13px", desktop: "14px", lh: "1.5",  ls: "0.06em", color: "text-text-5", use: "SectionLabel · nav, footer, labels" },
  { token: "label-xs",   mobile: "11px", desktop: "12px", lh: "1.4",  ls: "0.08em", color: "text-text-6", use: "SubsectionLabel · micro labels, tags" },
];
---

<BaseLayout
  title="Design System — Alejandro Moreno"
  description="Sistema de diseño del portfolio. Tokens, tipografía, componentes y patrones."
  lang={lang}
>
  <Nav lang={lang} />

  <main class="pt-20 pb-48 px-8">
    <div class="container-wide">

      <!-- Header -->
      <div class="mb-20 pb-10 border-b-[0.5px] border-[var(--color-border-subtle)]">
        <p class="font-data text-label-sm text-primary-500 mb-3 tracking-widest uppercase">Portfolio</p>
        <h1 class="text-display-lg font-display font-bold text-text-1 leading-[1.05] mb-4">Design System</h1>
        <p class="text-body-lg text-text-4 max-w-xl">
          Tokens, tipografía, componentes y patrones usados en el portfolio. Esta página vive dentro del proyecto y se mantiene alineada automáticamente con los estilos reales.
        </p>
      </div>

      <!-- ── 1. COLOR ──────────────────────────────────────────── -->
      <section class="mb-24" aria-labelledby="color-heading">
        <h2 id="color-heading" class="text-display-lg font-display font-bold text-text-1 mb-10">Color</h2>

        <!-- Primary -->
        <h3 class="text-body-lg font-display font-semibold text-text-2 mb-5">Primary — #E4A711</h3>
        <div class="flex flex-wrap gap-2 mb-12">
          {[50,100,200,300,400,500,600,700,800,900,950].map(n => (
            <div class="flex flex-col items-center gap-1.5">
              <div class={`w-12 h-12 rounded-none bg-primary-${n} border-[0.5px] border-[var(--color-border-subtle)]`} />
              <span class="font-data text-label-xs text-text-6">{n}</span>
            </div>
          ))}
        </div>

        <!-- Text hierarchy -->
        <h3 class="text-body-lg font-display font-semibold text-text-2 mb-2">Jerarquía de texto</h3>
        <p class="text-body-md text-text-5 mb-6">Regla: a mayor tamaño tipográfico → color más puro (text-1). A menor tamaño → color más apagado. El chrome de UI (nav, footer) usa siempre <code class="font-data text-primary-500">text-5</code> uniforme, sin excepciones.</p>
        <div class="flex flex-col gap-3 mb-12">
          {textTokens.map(t => (
            <div class="flex items-center gap-4">
              <code class="font-data text-label-sm text-primary-500 w-20 shrink-0">{t.token}</code>
              <div class="flex gap-2 shrink-0">
                <div class="w-6 h-6 rounded" style={`background: ${t.hex_dark}; border: 0.5px solid rgba(255,255,255,0.1)`} title={`dark: ${t.hex_dark}`}/>
                <div class="w-6 h-6 rounded border-[0.5px] border-[var(--color-border)]" style={`background: ${t.hex_light}`} title={`light: ${t.hex_light}`}/>
              </div>
              <span class={`text-body-md text-${t.token} flex-1`}>{t.use}</span>
            </div>
          ))}
        </div>

        <!-- Surfaces -->
        <h3 class="text-body-lg font-display font-semibold text-text-2 mb-5">Superficies y bordes</h3>
        <div class="flex flex-col gap-3">
          {surfaceTokens.map(s => (
            <div class="flex items-center gap-4">
              <code class="font-data text-label-sm text-primary-500 w-36 shrink-0">{s.token}</code>
              <div class="flex gap-2 shrink-0">
                <div class="w-6 h-6 rounded" style={`background: ${s.dark}; border: 0.5px solid rgba(255,255,255,0.15)`}/>
                <div class="w-6 h-6 rounded" style={`background: ${s.light}; border: 0.5px solid #d4ccba`}/>
              </div>
              <span class="text-body-md text-text-4">{s.label}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- ── 2. TIPOGRAFÍA ─────────────────────────────────────── -->
      <section class="mb-24" aria-labelledby="type-heading">
        <h2 id="type-heading" class="text-display-lg font-display font-bold text-text-1 mb-4">Tipografía</h2>
        <div class="flex gap-8 mb-10 text-body-md text-text-5">
          <span><strong class="text-text-3 font-semibold">Display / Body:</strong> Roboto Mono 400–700</span>
          <span><strong class="text-text-3 font-semibold">Data / Mono:</strong> Press Start 2P 400</span>
        </div>

        <div class="flex flex-col gap-6 mb-12">
          {typoScale.map(t => (
            <div class="flex items-baseline gap-6 py-3 border-b-[0.5px] border-[var(--color-border-subtle)]">
              <code class="font-data text-label-sm text-primary-500 w-28 shrink-0">{t.token}</code>
              <span class="font-data text-label-xs text-text-6 w-28 shrink-0">{t.mobile} / {t.desktop}</span>
              <span class={`font-display text-${t.token} ${t.color} leading-none`}>Aa</span>
              <span class="text-body-md text-text-5 ml-auto">{t.use}</span>
            </div>
          ))}
        </div>
        <p class="text-label-sm text-text-6 mb-12">Tamaños responsive via CSS vars — mobile (base) → desktop (768px+)</p>

        <!-- Color rules -->
        <h3 class="text-body-lg font-display font-semibold text-text-2 mb-4">Reglas de color en tipografía</h3>
        <div class="flex flex-col gap-3 mb-12 text-body-md">
          {[
            { context: "display-lg",  token: "text-text-1",     rule: "Título principal — máxima pureza." },
            { context: "display-md",  token: "text-text-2",     rule: "Título secundario." },
            { context: "body-lg",     token: "text-text-3",     rule: "Cuerpo grande, párrafos de introducción." },
            { context: "body-md",     token: "text-text-4",     rule: "Cuerpo principal." },
            { context: "label-sm",    token: "text-text-5",     rule: "SectionLabel (.section-label) · nav, footer, labels." },
            { context: "label-xs",    token: "text-text-6",     rule: "SubsectionLabel (.subsection-label) · micro labels, tags." },
            { context: "label-xs",    token: "text-text-6",     rule: "Micro labels, tags, detalles mínimos." },
            { context: "KPIs / datos", token: "text-primary-500", rule: "font-data (Press Start 2P). Números destacados." },
          ].map(r => (
            <div class="flex items-start gap-4 py-2 border-b-[0.5px] border-[var(--color-border-subtle)]">
              <code class="font-data text-label-sm text-primary-500 w-36 shrink-0">{r.context}</code>
              <code class="font-data text-label-sm text-text-4 w-28 shrink-0">{r.token}</code>
              <span class="text-text-5">{r.rule}</span>
            </div>
          ))}
        </div>

        <!-- Data type -->
        <h3 class="text-body-lg font-display font-semibold text-text-2 mb-4">Tipografía de datos</h3>
        <div class="flex items-baseline gap-8">
          <span class="font-data text-display-md font-bold text-primary-500">+82%</span>
          <span class="font-data text-display-md font-bold text-primary-500">€1.2M</span>
          <span class="font-data text-display-md font-bold text-primary-500">3×</span>
          <code class="font-data text-label-sm text-text-5 ml-4">font-data text-display-md font-bold text-primary-500</code>
        </div>
      </section>

      <!-- ── 3. GRADIENTES ─────────────────────────────────────── -->
      <section class="mb-24" aria-labelledby="gradient-heading">
        <h2 id="gradient-heading" class="text-display-lg font-display font-bold text-text-1 mb-8">Gradiente de texto</h2>
        <p class="text-body-md text-text-5 mb-6">Animado — usado en el roleHighlight del Hero. Fluye de oro a fucsia-rosa.</p>
        <div class="flex flex-col gap-4">
          <div>
            <span class="text-gradient font-display text-display-lg font-bold">Designer</span>
            <code class="font-data text-label-sm text-text-5 ml-4">.text-gradient</code>
          </div>
        </div>
      </section>

      <!-- ── 4. SOMBRAS ────────────────────────────────────────── -->
      <section class="mb-24" aria-labelledby="shadow-heading">
        <h2 id="shadow-heading" class="text-display-lg font-display font-bold text-text-1 mb-8">Sombras</h2>
        <p class="text-body-md text-text-5 mb-8">Multicapa con tinte dorado. Nunca usar shadow-md plana.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { name: "ds-sm",   label: "shadow-ds-sm",   desc: "Cards en reposo" },
            { name: "ds-md",   label: "shadow-ds-md",   desc: "Hover, modales" },
            { name: "ds-lg",   label: "shadow-ds-lg",   desc: "Dropdowns, popovers" },
            { name: "ds-glow", label: "shadow-ds-glow", desc: "Focus ring dorado" },
          ].map(s => (
            <div class={`p-6 rounded-none bg-surface-raised shadow-${s.name}`}>
              <code class="font-data text-label-sm text-primary-500 block mb-1">{s.label}</code>
              <span class="text-body-md text-text-5">{s.desc}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- ── 5. TRANSICIONES ───────────────────────────────────── -->
      <section class="mb-24" aria-labelledby="transition-heading">
        <h2 id="transition-heading" class="text-display-lg font-display font-bold text-text-1 mb-8">Transiciones</h2>
        <div class="flex gap-8 flex-wrap">
          {[
            { token: "duration-fast",   ms: "100ms", use: "Hover, color changes" },
            { token: "duration-normal", ms: "200ms", use: "Layouts, theme toggle" },
            { token: "duration-slow",   ms: "350ms", use: "Expansiones, modales" },
          ].map(t => (
            <div class="flex items-center gap-3">
              <code class="font-data text-label-sm text-primary-500">{t.token}</code>
              <span class="font-data text-label-sm text-text-5">{t.ms}</span>
              <span class="text-body-md text-text-6">— {t.use}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- ── 6. COMPONENTES ────────────────────────────────────── -->
      <section class="mb-24" aria-labelledby="components-heading">
        <h2 id="components-heading" class="text-display-lg font-display font-bold text-text-1 mb-12">Componentes</h2>

        <!-- SectionLabel / SubsectionLabel -->
        <div class="mb-14">
          <h3 class="text-body-lg font-display font-semibold text-text-2 mb-2">SectionLabel / SubsectionLabel</h3>
          <p class="text-body-md text-text-5 mb-6">Componentes atómicos para títulos de sección y subsección. Tipografía y color fijos — no admiten overrides de color.</p>
          <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-1">
              <p class="section-label">/experiencia</p>
              <code class="font-data text-label-xs text-text-6">SectionLabel label="/experiencia" — label-sm · text-5</code>
            </div>
            <div class="flex flex-col gap-1">
              <p class="subsection-label">Titulaciones</p>
              <code class="font-data text-label-xs text-text-6">SubsectionLabel label="Titulaciones" — label-xs · text-6</code>
            </div>
          </div>
        </div>

        <!-- Links -->
        <div class="mb-14">
          <h3 class="text-body-lg font-display font-semibold text-text-2 mb-2">Links</h3>
          <p class="text-body-md text-text-5 mb-6">Dos variantes: interno (navegación dentro del sitio) y externo (abre fuera). Sin subrayado, el color es el indicador de interactividad.</p>

          <!-- link-internal -->
          <div class="mb-8">
            <p class="text-label-xs text-text-6 font-display font-medium uppercase tracking-widest mb-4">link-internal</p>
            <div class="flex items-start gap-10 flex-wrap">
              <div class="flex flex-col gap-1 items-start">
                <a href="#" class="link-internal text-body-md">Alejandro Moreno</a>
                <span class="text-label-xs text-text-6 font-display">default</span>
              </div>
              <div class="flex flex-col gap-1 items-start">
                <a href="#" class="link-internal text-body-md" style="color: var(--color-text-2);">Alejandro Moreno</a>
                <span class="text-label-xs text-text-6 font-display">hover</span>
              </div>
              <div class="flex flex-col gap-1 items-start">
                <a href="#" class="link-internal text-body-md" style="outline: 2px solid #E4A711; outline-offset: 2px;">Alejandro Moreno</a>
                <span class="text-label-xs text-text-6 font-display">focus-visible</span>
              </div>
            </div>
            <code class="font-display text-label-xs text-text-6 mt-3 block">.link-internal — color text-4 → text-2 en hover</code>
          </div>

          <!-- link-external -->
          <div>
            <p class="text-label-xs text-text-6 font-display font-medium uppercase tracking-widest mb-4">link-external</p>
            <div class="flex items-start gap-10 flex-wrap">
              <div class="flex flex-col gap-1 items-start">
                <a href="#" class="link-external text-body-md">Figma</a>
                <span class="text-label-xs text-text-6 font-display">default</span>
              </div>
              <div class="flex flex-col gap-1 items-start">
                <span class="inline-flex items-center gap-[0.2rem] text-body-md font-medium" style="color: var(--color-text-2);">
                  Figma
                  <svg width="11" height="11" viewBox="0 0 20 20" fill="#E4A711" style="transform: translate(2px,-2px); flex-shrink:0;" aria-hidden="true">
                    <path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 0 0 1.06 0l7.22-7.22v5.69a.75.75 0 0 0 1.5 0v-7.5a.75.75 0 0 0-.75-.75h-7.5a.75.75 0 0 0 0 1.5h5.69l-7.22 7.22a.75.75 0 0 0 0 1.06Z" clip-rule="evenodd"/>
                  </svg>
                </span>
                <span class="text-label-xs text-text-6 font-display">hover</span>
              </div>
              <div class="flex flex-col gap-1 items-start">
                <a href="#" class="link-external text-body-md" style="outline: 2px solid #E4A711; outline-offset: 2px;">Figma</a>
                <span class="text-label-xs text-text-6 font-display">focus-visible</span>
              </div>
            </div>
            <code class="font-display text-label-xs text-text-6 mt-3 block">.link-external — igual que internal + flecha ↗ animada (lógica toolstack cards)</code>
          </div>
        </div>

        <!-- btn — todos los estados -->
        <div class="mb-14">
          <h3 class="text-body-lg font-display font-semibold text-text-2 mb-6">Btn — componente único</h3>
          <div class="flex flex-col gap-8">

            <div class="flex flex-col gap-2">
              <p class="font-body text-label-xs text-text-7 uppercase tracking-widest">Idle</p>
              <div class="flex items-center gap-4">
                <button class="btn font-body">Acción</button>
                <a href="#" class="btn font-body">Link</a>
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <p class="font-body text-label-xs text-text-7 uppercase tracking-widest">Hover — pasa el cursor</p>
              <div class="flex items-center gap-4">
                <button class="btn font-body" style="color:var(--color-primary);border-color:var(--color-primary);background:color-mix(in srgb,var(--color-primary) 6%,transparent)">Acción</button>
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <p class="font-body text-label-xs text-text-7 uppercase tracking-widest">Focused — tab / teclado</p>
              <div class="flex items-center gap-4">
                <button class="btn font-body" style="outline:none;box-shadow:0 0 0 1px var(--color-primary),0 0 14px rgba(228,167,17,0.9)">Acción</button>
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <p class="font-body text-label-xs text-text-7 uppercase tracking-widest">Active — al pulsar</p>
              <div class="flex items-center gap-4">
                <button class="btn font-body" style="color:var(--color-text-1);border-color:var(--color-primary);background:color-mix(in srgb,var(--color-primary) 12%,transparent)">Acción</button>
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <p class="font-body text-label-xs text-text-7 uppercase tracking-widest">Selected — página actual</p>
              <div class="flex items-center gap-4">
                <button class="btn font-body" aria-current="page">Acción</button>
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <p class="font-body text-label-xs text-text-7 uppercase tracking-widest">Disabled</p>
              <div class="flex items-center gap-4">
                <button class="btn font-body" disabled>Acción</button>
              </div>
            </div>

          </div>
          <code class="font-data text-label-xs text-text-6 mt-8 block">&lt;Btn&gt; — Btn.astro · estilos en global.css</code>
        </div>

        <!-- Dots -->
        <div class="mb-14">
          <h3 class="text-body-lg font-display font-semibold text-text-2 mb-2">Dots — indicadores</h3>
          <p class="text-body-md text-text-5 mb-6">Patrón unificado en TOC, carousel de proyectos y timeline de experiencia.</p>
          <div class="flex flex-col gap-6">
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3">
                <span class="block w-1.5 h-1.5 rounded-full bg-text-8"></span>
                <span class="block w-1.5 h-1.5 rounded-full bg-text-8"></span>
                <span class="block w-2 h-2 rounded-full" style="background:#E4A711; box-shadow: 0 0 0 3px rgba(228,167,17,0.2)"></span>
                <span class="block w-1.5 h-1.5 rounded-full bg-text-8"></span>
              </div>
              <code class="font-data text-label-xs text-text-6">reposo: 6×6 bg-text-8 — activo: 8×8 #E4A711 + glow ring</code>
            </div>
            <div class="flex items-center gap-6">
              <div class="flex items-center gap-3">
                <span class="block w-3.5 h-3.5 rounded-full bg-text-8" style="border: 0.5px solid var(--color-border-subtle)"></span>
                <span class="block w-3.5 h-3.5 rounded-full" style="background:#E4A711; box-shadow: 0 0 0 3px rgba(228,167,17,0.2)"></span>
              </div>
              <code class="font-data text-label-xs text-text-6">Timeline dot: 3.5px → activo gold + glow</code>
            </div>
          </div>
        </div>

        <!-- KPI -->
        <div class="mb-14">
          <h3 class="text-body-lg font-display font-semibold text-text-2 mb-2">KPI</h3>
          <p class="text-body-md text-text-5 mb-6">Componente <code class="font-data text-primary-500">&lt;Kpi value="+82%" label="Task completion" /&gt;</code>. Anima al entrar en viewport con counter de 1200ms ease-out. Separadores con divisor 1px.</p>
          <div class="flex items-start gap-8 p-6 rounded-none border-[0.5px] border-[var(--color-border-subtle)] bg-surface-raised">
            <div>
              <p class="font-data text-display-md font-bold text-primary-500 leading-none">+82%</p>
              <p class="text-label-sm text-text-6 mt-1">Task completion</p>
            </div>
            <div class="w-px h-8 self-center bg-[var(--color-border-subtle)]"></div>
            <div>
              <p class="font-data text-display-md font-bold text-primary-500 leading-none">€1.2M</p>
              <p class="text-label-sm text-text-6 mt-1">Pipeline growth</p>
            </div>
            <div class="w-px h-8 self-center bg-[var(--color-border-subtle)]"></div>
            <div>
              <p class="font-data text-display-md font-bold text-primary-500 leading-none">3×</p>
              <p class="text-label-sm text-text-6 mt-1">Client inquiries</p>
            </div>
          </div>
        </div>

        <!-- Tag / pill -->
        <div class="mb-14">
          <h3 class="text-body-lg font-display font-semibold text-text-2 mb-2">Tag / Pill</h3>
          <p class="text-body-md text-text-5 mb-6">Usado en stack de proyectos.</p>
          <div class="flex gap-2">
            {["Astro", "Tailwind CSS", "Figma", "React Native"].map(tag => (
              <span class="text-label-sm text-text-5 bg-surface-overlay border-[0.5px] border-[var(--color-border-subtle)] rounded-none px-3 py-1">{tag}</span>
            ))}
          </div>
        </div>

        <!-- Card work -->
        <div class="mb-14">
          <h3 class="text-body-lg font-display font-semibold text-text-2 mb-2">Card — Proyecto</h3>
          <p class="text-body-md text-text-5 mb-6">Layout horizontal: contenido (flex-1) + imagen (42%). En carousel, una card a la vez.</p>
          <div class="rounded-none border-[0.5px] border-[var(--color-border-subtle)] bg-surface overflow-hidden flex flex-col md:flex-row">
            <div class="flex flex-col flex-1 p-8">
              <span class="font-display text-label-sm font-semibold tracking-widest uppercase text-text-5 mb-5 block">Casa del Aire</span>
              <h4 class="font-display text-display-md font-bold text-text-2 leading-[1.1] mb-4">A booking-focused site that cut direct enquiry time by 60%</h4>
              <p class="text-body-md text-text-4 leading-relaxed flex-1 max-w-lg">Designed and developed the full website for a rural house in Extremadura, replacing a generic listing with a conversion-first experience owned by the client.</p>
              <div class="flex items-start gap-8 mt-8">
                <div><p class="font-data text-display-md font-bold text-primary-500 leading-none">–60%</p><p class="text-label-sm text-text-6 mt-1">Enquiry time</p></div>
                <div class="w-px h-8 self-center bg-[var(--color-border-subtle)]"></div>
                <div><p class="font-data text-display-md font-bold text-primary-500 leading-none">+40%</p><p class="text-label-sm text-text-6 mt-1">Direct bookings</p></div>
                <div class="w-px h-8 self-center bg-[var(--color-border-subtle)]"></div>
                <div><p class="font-data text-display-md font-bold text-primary-500 leading-none">100%</p><p class="text-label-sm text-text-6 mt-1">Brand ownership</p></div>
              </div>
            </div>
            <div class="md:w-[42%] shrink-0 min-h-[180px] bg-surface-overlay border-t-[0.5px] md:border-t-0 md:border-l-[0.5px] border-[var(--color-border-subtle)]"></div>
          </div>
        </div>

        <!-- Card craft -->
        <div class="mb-14">
          <h3 class="text-body-lg font-display font-semibold text-text-2 mb-2">Card — Herramienta (Craft)</h3>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-2xl">
            {[
              { title: "Figma", desc: "Core UI/UX design tool. Full cycle: wireframes, components, design systems and dev handoff." },
              { title: "Hotjar", desc: "User behaviour analytics: heatmaps, session recordings and conversion funnels." },
            ].map(tool => (
              <div class="flex flex-col p-7 rounded-none border-[0.5px] border-[var(--color-border-subtle)] bg-surface hover:bg-[var(--color-btn-hover-subtle)] transition-colors duration-fast">
                <div class="w-10 h-10 rounded-none bg-surface-overlay flex items-center justify-center text-primary-500 mb-5 text-label-sm font-bold">T</div>
                <div class="flex items-center gap-1.5 mb-2">
                  <h4 class="text-label-sm font-display font-semibold text-text-2">{tool.title}</h4>
                  <svg class="w-[15px] h-[15px] text-text-5 opacity-50" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 0 0 1.06 0l7.22-7.22v5.69a.75.75 0 0 0 1.5 0v-7.5a.75.75 0 0 0-.75-.75h-7.5a.75.75 0 0 0 0 1.5h5.69l-7.22 7.22a.75.75 0 0 0 0 1.06Z" clip-rule="evenodd" /></svg>
                </div>
                <p class="text-body-md text-text-4 leading-relaxed">{tool.desc}</p>
              </div>
            ))}
          </div>
        </div>

      </section>

      <!-- ── 7. JERARQUÍA TIPOGRÁFICA — REGLA ──────────────────── -->
      <section class="mb-24" aria-labelledby="rule-heading">
        <h2 id="rule-heading" class="text-display-lg font-display font-bold text-text-1 mb-6">Regla de jerarquía</h2>
        <p class="text-body-md text-text-5 mb-8">A mayor tamaño → color más puro. Nunca reutilizar text-1 en un nivel inmediatamente inferior que ya lo usa.</p>
        <div class="p-8 rounded-none border-[0.5px] border-[var(--color-border-subtle)] bg-surface-raised flex flex-col gap-4">
          {[
            { label: "Título principal",  size: "display-lg", color: "text-1" },
            { label: "Título de página",  size: "display-md", color: "text-2" },
            { label: "Lead / intro",      size: "body-lg",    color: "text-3" },
            { label: "Cuerpo principal",  size: "body-md",    color: "text-4" },
            { label: "Etiqueta / meta",   size: "label-sm",   color: "text-5" },
            { label: "Micro label",       size: "label-xs",   color: "text-6" },
          ].map(row => (
            <div class="flex items-center gap-4">
              <span class="text-body-md text-text-5 w-40 shrink-0">{row.label}</span>
              <code class="font-data text-label-xs text-primary-500 w-28 shrink-0">{row.size}</code>
              <code class="font-data text-label-xs text-text-6 w-16 shrink-0">{row.color}</code>
              <span class={`font-display text-${row.size} text-${row.color} leading-none`}>Ejemplo</span>
            </div>
          ))}
        </div>
      </section>

    </div>
  </main>
</BaseLayout>
