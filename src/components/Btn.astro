---
interface Props {
  href?:     string;
  class?:    string;
  id?:       string;
  disabled?: boolean;
  [key: string]: unknown;
}

const { href, class: className, ...rest } = Astro.props;
const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  class:list={["btn font-body", className]}
  {...rest}
>
  <slot />
</Tag>
