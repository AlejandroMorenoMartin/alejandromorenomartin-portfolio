---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);

/** Wrap numbers, percentages and currency amounts in data typography span */
function highlight(text: string): string {
  return text.replace(
    /(€[\d.,]+[MkK]?|\+?[\d.,]+\s*(?:M€|k€|%)|\b\d[\d.,]*\b)/g,
    '<span class="font-data text-primary-500 not-italic">$&</span>'
  );
}
---

<section id="experience" class="section-padding" aria-labelledby="experience-heading">
  <div class="container-wide">
    <h2 id="experience-heading" class="text-display-lg font-display font-bold text-text-1 mb-16">
      {t.experience.heading}
    </h2>

    <ol class="flex flex-col" role="list">
        {t.experience.items.map((item, i) => (
          <li
            class="timeline-item relative pl-8 pb-28 last:pb-0"
            data-index={String(i)}
          >
            <!-- Dot -->
            <div
              class="timeline-dot absolute left-0 top-1.5 w-3.5 h-3.5 rounded-full bg-text-8"
              aria-hidden="true"
            />

            <!-- Role -->
            <h3 class="text-label-lg font-display font-semibold text-text-1 leading-snug mb-1">
              {item.role}
            </h3>

            <!-- Company · period -->
            <p class="font-display text-label-sm text-text-5 italic mb-4">
              {item.company}
              <span class="not-italic mx-1 text-text-6">—</span>
              <span class="font-display text-text-5 italic">{item.period}</span>
            </p>

            <!-- Description with auto-highlighted data -->
            <p
              class="text-body-sm text-text-4 leading-relaxed"
              set:html={highlight(item.description)}
            />
          </li>
        ))}
      </ol>
  </div>
</section>

<style>
  .timeline-item {
    opacity: 0.35;
    transition: opacity 0.4s ease;
  }

  .timeline-item.is-active {
    opacity: 1;
  }

  .timeline-dot {
    transition: background-color 0.3s ease, box-shadow 0.3s ease;
  }

  .timeline-dot.is-active {
    background-color: #E4A711;
    box-shadow: 0 0 0 3px rgba(228, 167, 17, 0.2);
  }
</style>

<script>
  const items = Array.from(document.querySelectorAll<HTMLElement>('.timeline-item'));

  let activeIndex = -1;

  function setActive(index: number): void {
    if (index === activeIndex) return;
    activeIndex = index;
    items.forEach((item, i) => {
      const active = i === index;
      item.classList.toggle('is-active', active);
      item.querySelector('.timeline-dot')?.classList.toggle('is-active', active);
    });
  }

  function getActiveIndex(): number {
    const triggerY = window.scrollY + window.innerHeight * 0.35;
    let best = 0;
    let bestDist = Infinity;
    items.forEach((item, i) => {
      const dotDocY = item.getBoundingClientRect().top + window.scrollY;
      const dist = Math.abs(dotDocY - triggerY);
      if (dist < bestDist) { bestDist = dist; best = i; }
    });
    return best;
  }

  window.addEventListener('scroll', () => setActive(getActiveIndex()), { passive: true });
  setActive(getActiveIndex());
</script>
