---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";
import Kpi from "@/components/Kpi.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);

/** Wrap numbers, percentages and currency amounts in data typography span */
function highlight(text: string): string {
  return text.replace(
    /(€[\d.,]+[MkK]?|\+?[\d.,]+\s*(?:M€|k€|%)|\b(?!(?:19|20)\d{2}\b)\d[\d.,]*\b)/g,
    '<span class="text-primary-500 not-italic">$&</span>'
  );
}
---

<section id="experience" class="section-padding" aria-label={t.experience.heading}>
  <div class="container-wide">
    <p class="font-body text-label-xs text-text-7" style="margin-bottom: var(--section-gap)">/experiencia</p>
    <ol class="flex flex-col" role="list">
      {t.experience.items.map((item, i) => (
        <li
          class="timeline-item relative pl-8 last:pb-0"
          style="padding-bottom: var(--page-gap)"
          data-index={String(i)}
        >
          <!-- Dot -->
          <div class="timeline-dot absolute left-0" aria-hidden="true" />

          <div class="experience-card">
            <!-- Header -->
            <div class="card-header">
              <p class="font-body text-label-xs text-text-7">{item.company} - {item.period}</p>
              <h3 class="font-display text-body-lg text-text-3 leading-snug">{item.role}</h3>
            </div>

            <!-- Description -->
            <p
              class="text-body-md text-text-4 leading-relaxed"
              set:html={highlight(item.description)}
            />

            <!-- KPI metrics -->
            {item.metrics && item.metrics.length > 0 && (
              <div class="flex items-start" style="gap: var(--card-gap)">
                {item.metrics.map((metric, i) => (
                  <>
                    <Kpi value={metric.value} label={metric.label} class="kpi-managed" />
                    {i < item.metrics.length - 1 && (
                      <div class="w-px h-8 self-center bg-[var(--color-border-subtle)]" aria-hidden="true" />
                    )}
                  </>
                ))}
              </div>
            )}

          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .experience-card {
    display:        flex;
    flex-direction: column;
    gap:            var(--card-gap);
  }

  .card-header {
    display:        flex;
    flex-direction: column;
    gap:            0.5rem;
  }

  .timeline-dot {
    width:       8px;
    height:      8px;
    top:         calc((var(--fs-label-xs) * 1.4 - 8px) / 2);
    background:  var(--color-text-7);
    flex-shrink: 0;
    transition:  background-color 0.2s, width 0.2s, height 0.2s;
  }

  .timeline-dot.is-active {
    background: var(--color-primary);
    width:      10px;
    height:     10px;
  }
</style>

<script>
  (function () {
    const DURATION_MS = 1200;
    const ease = (t: number) => 1 - Math.pow(1 - t, 3);

    function animateKpi(el: HTMLElement): void {
      if (el.dataset.kpiDone) return;
      el.dataset.kpiDone = "1";
      const target   = parseFloat(el.dataset.kpiTarget   ?? "0");
      const decimals = parseInt(el.dataset.kpiDecimals   ?? "0", 10);
      const prefix   = el.dataset.kpiPrefix ?? "";
      const suffix   = el.dataset.kpiSuffix ?? "";
      const start    = performance.now();
      function frame(now: number): void {
        const progress = Math.min((now - start) / DURATION_MS, 1);
        el.textContent = `${prefix}${(target * ease(progress)).toFixed(decimals)}${suffix}`;
        if (progress < 1) requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    }

    const items = Array.from(document.querySelectorAll<HTMLElement>(".timeline-item"));
    const dots  = items.map(item => item.querySelector<HTMLElement>(".timeline-dot"));

    function setActive(index: number): void {
      dots.forEach((dot, i) => dot?.classList.toggle("is-active", i === index));
      items[index]
        ?.querySelectorAll<HTMLElement>(".kpi-value")
        .forEach(animateKpi);
    }

    function getActiveIndex(): number {
      const scroll    = document.getElementById("main-scroll");
      const scrollTop = scroll ? scroll.scrollTop : window.scrollY;
      const viewH     = scroll ? scroll.clientHeight : window.innerHeight;
      const trigger   = scrollTop + viewH * 0.4;
      let best = 0, bestDist = Infinity;
      items.forEach((item, i) => {
        const dist = Math.abs(item.offsetTop - trigger);
        if (dist < bestDist) { bestDist = dist; best = i; }
      });
      return best;
    }

    const scroll = document.getElementById("main-scroll");
    (scroll ?? window).addEventListener("scroll", () => setActive(getActiveIndex()), { passive: true });
    setActive(getActiveIndex());
  })();
</script>
