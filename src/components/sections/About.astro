---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);
---

<section id="about" class="section-padding" aria-labelledby="about-heading">
  <div class="container-wide">
    <!-- Label -->
    <p class="text-label-sm text-primary-500 font-display font-medium tracking-widest uppercase mb-3">
      {t.about.label}
    </p>

    <div class="grid md:grid-cols-2 gap-16 items-center">
      <!-- Text -->
      <div>
        <h2 id="about-heading" class="text-display-lg font-display font-bold text-text-1 mb-8">
          {t.about.heading}
        </h2>

        <div class="flex flex-col gap-5">
          <p class="text-body-md text-text-3 leading-relaxed">{t.about.p1}</p>
          <p class="text-body-md text-text-3 leading-relaxed">{t.about.p2}</p>
          <p class="text-body-md text-text-3 leading-relaxed">{t.about.p3}</p>
        </div>

        <div class="mt-8 inline-flex items-center gap-2 text-label-sm text-text-5 border border-border rounded-full px-4 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse" />
          {t.about.available}
        </div>
      </div>

      <!-- Photo -->
      <div class="flex justify-center md:justify-end">
        <div class="relative">
          <!-- Glow ring -->
          <div class="absolute inset-0 rounded-2xl scale-[1.04] bg-gradient-to-br from-primary-500/20 to-transparent blur-2xl" aria-hidden="true" />
          <div class="relative w-72 h-80 md:w-80 md:h-96 rounded-2xl overflow-hidden border border-border shadow-ds-lg">
            <img
              src="/profile.png"
              alt="Alejandro Moreno Martín — Product Designer"
              class="w-full h-full object-cover object-top"
              loading="lazy"
              decoding="async"
              width="320"
              height="384"
            />
            <!-- Subtle overlay gradient at bottom -->
            <div class="absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-surface/60 to-transparent" aria-hidden="true" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
