---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";
import Kpi from "@/components/Kpi.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);
---

<section id="about" class="section-padding" aria-labelledby="about-heading">
  <div class="container-wide">
    <div class="grid md:grid-cols-2 gap-4 items-center">

      <!-- Text -->
      <div>
        <h2 id="about-heading" class="text-display-lg font-display font-bold text-text-1 mb-3">
          {t.about.heading}
        </h2>

        <!-- Location -->
        <div class="flex items-center gap-1.5 mb-8">
          <svg class="w-3.5 h-3.5 text-primary-500 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
          </svg>
          <span class="font-display text-label-sm text-text-5">{t.hero.location}</span>
        </div>

        <div class="flex flex-col gap-5">
          <p class="text-body-md text-text-3 leading-relaxed">{t.about.p1}</p>
          <p class="text-body-md text-text-3 leading-relaxed">{t.about.p2}</p>
          <p class="text-body-md text-text-3 leading-relaxed">{t.about.p3}</p>
        </div>

        <!-- Stats -->
        <div class="flex items-center gap-8 mt-10">
          {t.about.stats.map((stat, i) => (
            <>
              <Kpi value={stat.value} label={stat.label} />
              {i < t.about.stats.length - 1 && (
                <div class="w-px h-8 bg-[var(--color-border-subtle)]" aria-hidden="true" />
              )}
            </>
          ))}
        </div>
      </div>

      <!-- Photo -->
      <div class="flex justify-center md:justify-end">
        <div class="w-72 h-72 md:w-80 md:h-80 rounded-none overflow-hidden border-[0.5px] border-[var(--color-border-subtle)]">
          <img
            src="/profile.png"
            alt="Alejandro Moreno Martín — Product Designer"
            class="w-full h-full object-cover object-center"
            loading="lazy"
            decoding="async"
            width="320"
            height="320"
          />
        </div>
      </div>

    </div>
  </div>
</section>
