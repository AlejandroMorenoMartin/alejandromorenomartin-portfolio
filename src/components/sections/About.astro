---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";
import Kpi          from "@/components/Kpi.astro";
import SectionLabel from "@/components/SectionLabel.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);
---

<section id="about" class="section-padding" aria-label={t.about.heading}>
  <div class="container-wide">
    <SectionLabel label="/perfil" />
    <div class="grid md:grid-cols-[1fr_auto] items-center" style="gap: var(--section-gap)">

      <!-- Text -->
      <div>

        <div class="flex flex-col" style="gap: var(--section-gap)">
          <p class="text-body-md text-text-3 leading-relaxed">{t.about.p1}</p>
          <p class="text-body-md text-text-3 leading-relaxed">{t.about.p2}</p>
        </div>

        <!-- Stats -->
        <div class="flex items-start gap-6 md:gap-8" style="margin-top: var(--section-gap)">
          {t.about.stats.map((stat, i) => (
            <>
              <Kpi value={stat.value} label={stat.label} />
              {i < t.about.stats.length - 1 && (
                <div class="hidden md:block w-px h-8 self-center bg-[var(--color-border-subtle)]" aria-hidden="true" />
              )}
            </>
          ))}
        </div>
      </div>

      <!-- Photo -->
      <div>
        <div class="w-full h-72 md:w-80 md:h-80 rounded-none overflow-hidden border-[0.5px] border-[var(--color-border-subtle)]">
          <img
            src="/profile.png"
            alt="Alejandro Moreno Martín — Product Designer"
            class="w-full h-full object-cover object-center"
            loading="lazy"
            decoding="async"
            width="320"
            height="320"
          />
        </div>
      </div>

    </div>
  </div>
</section>
