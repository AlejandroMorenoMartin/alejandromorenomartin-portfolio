---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";
import SectionLabel        from "@/components/SectionLabel.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);

const allItems = [
  ...t.education.certifications.items.map((item) => ({
    category:       t.education.table.certification,
    title:          item.title,
    institution:    item.issuer,
    institutionUrl: item.issuerUrl ?? null,
    year:           item.year,
  })),
  ...t.education.degrees.items.map((item) => ({
    category:       t.education.table.degree,
    title:          item.title,
    institution:    item.institution,
    institutionUrl: item.institutionUrl ?? null,
    year:           item.period.split("—")[1]?.trim() ?? item.period,
  })),
].sort((a, b) => Number(b.year) - Number(a.year));
---

<section id="education" class="section-padding" aria-label={t.education.heading}>
  <div class="container-wide">
    <SectionLabel label={lang === "en" ? "/education" : "/educación"} />

    <div class="edu-scroll">
      <table class="edu-table">
        <thead>
          <tr class="edu-header-row">
            <th class="subsection-label text-left font-normal pb-3 pr-6">{t.education.table.category}</th>
            <th class="subsection-label text-left font-normal pb-3 pr-6">{t.education.table.name}</th>
            <th class="subsection-label text-left font-normal pb-3 pr-6">{t.education.table.institution}</th>
            <th class="subsection-label text-left font-normal pb-3">{t.education.table.year}</th>
          </tr>
        </thead>
        <tbody>
          {allItems.map((item) => (
            <tr class="edu-row">
              <td class="font-body text-label-xs py-3 pr-6">{item.category}</td>
              <td class="font-body text-label-xs py-3 pr-6">{item.title}</td>
              <td class="font-body text-label-xs py-3 pr-6">
                {item.institutionUrl
                  ? <a href={item.institutionUrl} target="_blank" rel="noopener noreferrer" class="link-external">{item.institution}</a>
                  : item.institution}
              </td>
              <td class="font-body text-label-xs py-3">{item.year}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .edu-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .edu-table {
    width:           100%;
    min-width:       520px;
    border-collapse: collapse;
  }

  .edu-header-row {
    border-bottom: 1px solid var(--color-border-subtle);
  }

</style>
