---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";
import SectionLabel        from "@/components/SectionLabel.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);

const allItems = [
  ...t.education.certifications.items.map((item) => ({
    category:    "Certificación",
    title:       item.title,
    institution: item.issuer,
    year:        item.year,
  })),
  ...t.education.degrees.items.map((item) => ({
    category:    "Titulación",
    title:       item.title,
    institution: item.institution,
    year:        item.period.split("—")[1]?.trim() ?? item.period,
  })),
].sort((a, b) => Number(b.year) - Number(a.year));
---

<section id="education" class="section-padding" aria-label={t.education.heading}>
  <div class="container-wide">
    <SectionLabel label="/educación" />

    <table class="edu-table">
      <thead>
        <tr class="edu-header-row">
          <th class="tag text-left font-normal pb-3 pr-6">Categoría</th>
          <th class="tag text-left font-normal pb-3 pr-6">Nombre</th>
          <th class="tag text-left font-normal pb-3 pr-6">Institución</th>
          <th class="tag text-left font-normal pb-3">Año</th>
        </tr>
      </thead>
      <tbody>
        {allItems.map((item) => (
          <tr class="edu-row">
            <td class="font-body text-label-xs py-3 pr-6">{item.category}</td>
            <td class="font-display text-label-sm text-text-3 py-3 pr-6">{item.title}</td>
            <td class="font-display text-label-sm italic py-3 pr-6">{item.institution}</td>
            <td class="font-body text-label-xs py-3">{item.year}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style>
  .edu-table {
    width:           100%;
    border-collapse: collapse;
  }

  .edu-header-row {
    border-bottom: 1px solid var(--color-border-subtle);
  }

</style>
