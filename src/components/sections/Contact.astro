---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);

const EMAIL    = "alejandromorenomartin1990@gmail.com";
const LINKEDIN = "https://www.linkedin.com/in/alejandromorenomartin";
const GITHUB   = "https://github.com/kakomoma";
---

<section id="contact" class="section-padding" aria-labelledby="contact-heading">
  <div class="container-wide">
    <div class="max-w-2xl">
      <p class="text-label-sm text-primary-500 font-display font-medium tracking-widest uppercase mb-3">
        {t.contact.label}
      </p>
      <h2 id="contact-heading" class="text-display-lg font-display font-bold text-text-1 mb-6">
        {t.contact.heading}
      </h2>
      <p class="text-body-lg text-text-4 leading-relaxed mb-10">
        {t.contact.description}
      </p>

      <!-- CTA links -->
      <div class="flex flex-wrap gap-4">
        <a
          href={`mailto:${EMAIL}`}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-none bg-primary-500 text-[#0a0a0a] font-display font-semibold text-label-lg transition-all duration-fast hover:bg-primary-400 active:scale-95 shadow-ds-glow"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          {t.contact.email}
        </a>

        <a
          href={LINKEDIN}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-none border border-border text-text-3 font-display font-medium text-label-lg transition-all duration-fast hover:border-border-strong hover:text-text-1 active:scale-95"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          {t.contact.linkedin}
        </a>

        <a
          href={GITHUB}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-none border border-border text-text-3 font-display font-medium text-label-lg transition-all duration-fast hover:border-border-strong hover:text-text-1 active:scale-95"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
          {t.contact.github}
        </a>
      </div>

      <!-- Available for -->
      <p class="mt-10 text-label-sm text-text-6">
        {t.contact.availableFor}
      </p>
    </div>
  </div>
</section>
