---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";
import SectionLabel from "@/components/SectionLabel.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);
---

<section id="metodo" class="section-padding" aria-label={t.metodo.label}>
  <div class="container-wide">
    <SectionLabel label={t.metodo.label} />
    <div class="metodo-content">
      <p class="text-body-md text-text-3 leading-relaxed">{t.metodo.p1}</p>
      <p class="text-body-md leading-relaxed">{t.metodo.p2}</p>
    </div>
  </div>
</section>

<style>
  .metodo-content {
    display:        flex;
    flex-direction: column;
    gap:            var(--section-gap);
  }
</style>
