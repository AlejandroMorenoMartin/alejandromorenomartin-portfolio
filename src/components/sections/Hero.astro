---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);
---

<section
  id="hero"
  class="relative overflow-hidden min-h-screen flex flex-col justify-center section-padding pt-32 pb-24"
  aria-label="Hero"
>
  <!-- Ambient glow: primary circle, top-right — MUTED, retomar más adelante -->
  <!-- <div class="ambient-orb absolute -top-32 -right-32 w-[640px] h-[640px] rounded-full pointer-events-none" aria-hidden="true" /> -->

  <div class="container-wide">
    <div class="max-w-3xl mx-auto text-center">

      <!-- Greeting -->
      <div id="hero-greeting" class="flex items-center justify-center gap-3 mb-10" aria-label={t.hero.greeting}>
        <span class="wave-emoji text-5xl" aria-hidden="true">👋</span>
        <span class="font-display text-display-lg text-text-6">
          <span id="greeting-text" data-text={t.hero.greeting}></span><span class="cursor" aria-hidden="true">|</span>
        </span>
      </div>

      <!-- Main content — hidden until greeting finishes -->
      <div id="hero-main">

        <h1 class="text-display-2xl md:text-[5rem] font-display font-bold text-text-1 leading-[1.05] mb-2">
          {t.hero.name}
        </h1>

        <h2 class="text-display-lg md:text-[2.75rem] font-display font-semibold text-text-3 leading-tight mb-6">
          {t.hero.rolePrefix}<span class="text-gradient">{t.hero.roleHighlight}</span>
        </h2>

        <p class="text-body-lg text-text-5 max-w-xl mx-auto">
          {t.hero.tagline}
        </p>

        <!-- Thinking widget -->
        <div class="thinking-widget" aria-label="En proceso creativo" data-verbs={JSON.stringify(t.hero.thinking)}>
          <span style="display:inline-flex;flex-shrink:0;width:18px;height:18px;align-self:center;" aria-hidden="true">
          <img src="/alejandro-icon-nav.svg" alt="" style="width:18px;height:18px;object-fit:contain;" />
        </span>
          <span class="thinking-verb-wrap" aria-live="polite">
            <span id="thinking-verb"></span><span class="thinking-cursor" aria-hidden="true">|</span>
          </span>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  /* ── Greeting ─────────────────────────────────────── */
  #hero-greeting {
    opacity: 0;
    transform: translateY(10px);
    animation: fadeUp 0.69s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 250ms;
  }

  /* Ola inicial — se dispara una vez al cargar */
  @keyframes wave {
    0%   { transform: rotate(0deg);  }
    15%  { transform: rotate(22deg); }
    35%  { transform: rotate(-8deg); }
    50%  { transform: rotate(18deg); }
    65%  { transform: rotate(-4deg); }
    80%  { transform: rotate(10deg); }
    100% { transform: rotate(0deg);  }
  }

  .wave-emoji {
    display: inline-block;
    transform-origin: 70% 80%;
  }

  .wave-emoji.is-waving {
    animation: wave 1.1s ease-in-out both;
  }

  .cursor {
    display: inline-block;
    color: var(--color-primary);
    animation: blink 0.75s step-end infinite;
    margin-left: 1px;
    transition: opacity 0.35s ease;
  }
  .cursor.is-hidden {
    opacity: 0;
    animation: none;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ── Main content ─────────────────────────────────── */
  #hero-main > * {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity   0.94s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.94s cubic-bezier(0.16, 1, 0.3, 1);
  }

  #hero-main.is-visible > *:nth-child(1) { opacity: 1; transform: none; transition-delay:   0ms; }
  #hero-main.is-visible > *:nth-child(2) { opacity: 1; transform: none; transition-delay: 141ms; }
  #hero-main.is-visible > *:nth-child(3) { opacity: 1; transform: none; transition-delay: 281ms; }
  #hero-main.is-visible > *:nth-child(4) { opacity: 1; transform: none; transition-delay: 380ms; }

  /* ── Thinking widget ─────────────────────────────── */
  .thinking-widget {
    display:         inline-flex;
    align-items:     center;
    justify-content: center;
    gap:             0.5rem;
    margin-top:      1.5rem;
  }

  .thinking-verb-wrap {
    font-family: 'Poppins', sans-serif;
    font-size:   0.8125rem;
    color:       var(--color-text-4);
    display:     inline-flex;
    align-items: baseline;
    gap:         1px;
  }

  .thinking-cursor {
    color:     var(--color-primary);
    animation: cursor-blink 0.75s step-end infinite;
    margin-left: 1px;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ── Shared ───────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Ambient orb (muted) ──────────────────────────── */
  @keyframes orbFloat {
    0%   { transform: translate(0, 0) scale(1); }
    33%  { transform: translate(-40px, 30px) scale(1.08); }
    66%  { transform: translate(20px, -20px) scale(0.95); }
    100% { transform: translate(0, 0) scale(1); }
  }

  .ambient-orb {
    background: radial-gradient(circle, color-mix(in srgb, #E4A711 25%, transparent), transparent 70%);
    filter: blur(80px);
    animation: orbFloat 8s ease-in-out infinite;
    will-change: transform;
  }
</style>

<script>
  // ── Thinking widget — typewriter effect ─────────────────────
  const thinkingWidget = document.querySelector(".thinking-widget") as HTMLElement;
  const thinkingVerb   = document.getElementById("thinking-verb")  as HTMLSpanElement;

  if (thinkingWidget && thinkingVerb) {
    const verbs: string[] = JSON.parse(thinkingWidget.dataset.verbs ?? "[]");
    let idx = 0;

    const CHAR_DELAY        = 80;
    const DELETE_DELAY      = 45;
    const PAUSE_AFTER_TYPE  = 1800;
    const PAUSE_AFTER_DEL   = 150;

    function typeText(text: string, onDone: () => void): void {
      let i = 0;
      thinkingVerb.textContent = "";
      const tick = (): void => {
        thinkingVerb.textContent = text.slice(0, ++i);
        if (i < text.length) setTimeout(tick, CHAR_DELAY);
        else onDone();
      };
      setTimeout(tick, CHAR_DELAY);
    }

    function deleteText(onDone: () => void): void {
      const tick = (): void => {
        const cur = thinkingVerb.textContent ?? "";
        if (cur.length === 0) { onDone(); return; }
        thinkingVerb.textContent = cur.slice(0, -1);
        setTimeout(tick, DELETE_DELAY);
      };
      tick();
    }

    function cycle(): void {
      typeText(verbs[idx], () => {
        setTimeout(() => {
          deleteText(() => {
            setTimeout(() => {
              idx = (idx + 1) % verbs.length;
              cycle();
            }, PAUSE_AFTER_DEL);
          });
        }, PAUSE_AFTER_TYPE);
      });
    }

    cycle();
  }

  // ── Greeting + main ─────────────────────────────────────────
  const greetingText = document.getElementById("greeting-text") as HTMLSpanElement;
  const cursor       = document.querySelector(".cursor")         as HTMLSpanElement;
  const heroMain     = document.getElementById("hero-main")      as HTMLDivElement;
  const waveEmoji    = document.querySelector(".wave-emoji")     as HTMLSpanElement;

  const text           = greetingText.dataset.text ?? "";
  const CHAR_DELAY_MS  = 75;   // ms between each character (+25%)
  const POST_TYPE_MS   = 475;  // pause after last char before revealing content (+25%)

  function triggerWave(): void {
    waveEmoji.classList.remove("is-waving");
    void waveEmoji.offsetWidth; // force reflow to restart animation
    waveEmoji.classList.add("is-waving");
  }

  // Hover: ola inmediata
  waveEmoji.addEventListener("mouseenter", triggerWave);

  // IntersectionObserver: dispara la ola cada vez que el hero entra en pantalla
  const heroSection = document.getElementById("hero")!;
  const waveObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) triggerWave();
      });
    },
    { threshold: 0.4 }
  );
  waveObserver.observe(heroSection);

  // Wait for greeting to fade in, then start typing
  setTimeout(() => {
    // Ola inicial al cargar
    triggerWave();

    let i = 0;
    const type = () => {
      if (i < text.length) {
        greetingText.textContent += text[i];
        i++;
        setTimeout(type, CHAR_DELAY_MS);
      } else {
        // Typing done — hide cursor, reveal main content
        setTimeout(() => {
          cursor.classList.add("is-hidden");
          heroMain.classList.add("is-visible");

          // TOC aparece cuando el último elemento (Madrid) ha terminado de entrar:
          // delay del 4.º hijo (406ms) + duración transición (940ms) = 1346ms
          setTimeout(() => {
            document.dispatchEvent(new CustomEvent("hero:done"));
          }, 1350);
        }, POST_TYPE_MS);
      }
    };

    type();
  }, 938); // greeting fade-in: 250ms delay + 690ms duration (+25%)
</script>
