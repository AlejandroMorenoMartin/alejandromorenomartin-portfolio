---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);
---

<section
  id="hero"
  class="min-h-screen flex flex-col justify-center section-padding pt-32 pb-24"
  aria-label="Hero"
>
  <div class="container-wide">
    <div class="max-w-3xl">
      <!-- Greeting -->
      <p class="text-label-sm text-primary-500 font-display font-medium tracking-widest uppercase mb-4 opacity-0 animate-fade-up" style="--delay: 0ms">
        {t.hero.greeting}
      </p>

      <!-- Name -->
      <h1 class="text-display-2xl md:text-[5rem] font-display font-bold text-text-1 leading-[1.05] mb-4 opacity-0 animate-fade-up" style="--delay: 80ms">
        {t.hero.name}
        <br />
        <span class="text-gradient">{t.hero.role}</span>
      </h1>

      <!-- Tagline -->
      <p class="text-body-lg text-text-4 max-w-xl mt-6 opacity-0 animate-fade-up" style="--delay: 160ms">
        {t.hero.tagline}
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 mt-10 opacity-0 animate-fade-up" style="--delay: 240ms">
        <a
          href="#work"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-primary-500 text-[#0a0a0a] font-display font-semibold text-label-lg transition-all duration-fast hover:bg-primary-400 active:scale-95 shadow-ds-glow"
        >
          {t.hero.cta}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href="#about"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-border text-text-3 font-display font-medium text-label-lg transition-all duration-fast hover:border-border-strong hover:text-text-1 active:scale-95"
        >
          {t.hero.ctaSecondary}
        </a>
      </div>

      <!-- Availability pill -->
      <div class="mt-12 opacity-0 animate-fade-up" style="--delay: 320ms">
        <span class="inline-flex items-center gap-2 text-label-sm text-text-5 border border-border rounded-full px-4 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse" />
          {t.about.available}
        </span>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-text-7 opacity-0 animate-fade-up" style="--delay: 500ms" aria-hidden="true">
      <span class="text-label-sm tracking-widest uppercase text-[10px]">scroll</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-bounce">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-up {
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: var(--delay, 0ms);
  }
</style>
