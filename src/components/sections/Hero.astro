---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";


interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);
---

<section
  id="hero"
  class="section-padding"
  aria-label="Hero"
>
  <div class="container-wide hero-content">

    <!-- Identity card -->
    <div class="hero-card">
      <div class="hero-heading">
        <p class="tag">Product Designer</p>
        <h2 class="text-display-lg"><span class="hero-initial text-primary-500">A</span>lejandro Moreno Martín</h2>
      </div>
      <p class="text-body-md text-text-3 leading-relaxed">{t.hero.greeting}</p>
      <p class="text-body-md leading-relaxed">{t.hero.tagline}</p>
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        <a href="mailto:alejandromorenomartin1990@gmail.com" class="link-external text-body-md">Email</a>
        <a href="https://wa.me/34618110583" target="_blank" rel="noopener noreferrer" class="link-external text-body-md">WhatsApp</a>
        <a href="https://www.linkedin.com/in/alejandromorenomartin" target="_blank" rel="noopener noreferrer" class="link-external text-body-md">LinkedIn</a>
      </div>
    </div>

    <!-- Typewriter -->
    <div class="thinking-widget" aria-label="Estado de procesamiento">
      <span class="thinking-verb-wrap font-body" aria-live="polite" data-verbs={JSON.stringify(t.hero.thinking)}>
        <span id="thinking-verb"></span><span class="thinking-cursor" aria-hidden="true"></span>
      </span>
    </div>

  </div>
</section>

<style>
  .hero-initial {
    font-family:    'Press Start 2P', monospace;
    vertical-align: baseline;
    line-height:    1;
    position:       relative;
    top:            4px;
  }

  /* ── Layout ──────────────────────────────────────── */
  .hero-content {
    display:        flex;
    flex-direction: column;
    align-items:    flex-start;
    gap:            var(--page-gap);
  }

  .hero-card {
    display:        flex;
    flex-direction: column;
    gap:            var(--card-gap);
  }

  .hero-heading {
    display:        flex;
    flex-direction: column;
    gap:            0.5rem;
  }

  /* ── Thinking widget ─────────────────────────────── */
  .thinking-widget {
    display:    flex;
    align-items: center;
    min-height: calc(var(--fs-body-md) * 1.6);
  }

  .thinking-verb-wrap {
    font-size:   var(--fs-body-md);
    color:       var(--color-primary);
    display:     inline-flex;
    align-items: baseline;
    gap:         2px;
  }

  .thinking-verb-wrap.is-complete #thinking-verb {
    text-shadow: 0 0 8px rgba(228, 167, 17, 0.6);
  }

  .thinking-cursor {
    display:          inline-block;
    width:            0.25em;
    height:           1em;
    background-color: var(--color-primary);
    vertical-align:   -0.25em;
    animation:        cursor-blink 1s step-end infinite;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<script>
  const CHAR_DELAY       = 50;
  const DELETE_DELAY     = 30;
  const PAUSE_AFTER_TYPE = 2000;
  const PAUSE_AFTER_DEL  = 150;

  const wrap  = document.querySelector(".thinking-verb-wrap") as HTMLElement;
  const verb  = document.getElementById("thinking-verb")     as HTMLSpanElement;

  const rawVerbs = wrap?.dataset.verbs;
  const VERBS: string[] = rawVerbs
    ? (JSON.parse(rawVerbs) as string[]).map(v => v.toUpperCase() + "...")
    : [];

  if (wrap && verb) {
    let idx = 0;

    function typeText(text: string, onDone: () => void): void {
      let i = 0;
      verb.textContent = "";
      wrap.classList.remove("is-complete");
      const tick = (): void => {
        verb.textContent = text.slice(0, ++i);
        if (i < text.length) {
          setTimeout(tick, CHAR_DELAY);
        } else {
          wrap.classList.add("is-complete");
          onDone();
        }
      };
      setTimeout(tick, CHAR_DELAY);
    }

    function deleteText(onDone: () => void): void {
      wrap.classList.remove("is-complete");
      const tick = (): void => {
        const cur = verb.textContent ?? "";
        if (cur.length === 0) { onDone(); return; }
        verb.textContent = cur.slice(0, -1);
        setTimeout(tick, DELETE_DELAY);
      };
      tick();
    }

    function cycle(): void {
      typeText(VERBS[idx], () => {
        setTimeout(() => {
          deleteText(() => {
            setTimeout(() => {
              idx = (idx + 1) % VERBS.length;
              cycle();
            }, PAUSE_AFTER_DEL);
          });
        }, PAUSE_AFTER_TYPE);
      });
    }

    cycle();
  }
</script>
