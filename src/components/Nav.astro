---
import type { Lang } from "@/i18n/utils";
import pkg from "../../package.json";

interface Props {
  lang: Lang;
}

const { lang }   = Astro.props;
const version    = `V.${pkg.version}`;
const pathname   = Astro.url.pathname;

const navLinks = [
  { href: "/",            label: "Inicio" },
  { href: "/proyectos",   label: "Proyectos" },
  { href: "/sobre-mi",    label: "Sobre mí" },
  { href: "/trayectoria", label: "Trayectoria" },
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/" || pathname === "";
  return pathname === href || pathname === href + "/";
}
---

<header
  id="nav"
  class="fixed top-0 inset-x-0 z-50 bg-surface border-b border-[var(--color-border-subtle)]"
  aria-label="Main navigation"
>
  <div style="max-width:1024px;margin-inline:auto;">
    <nav class="flex items-center justify-between h-12">

      <!-- Left: project name + version -->
      <div class="flex items-center">
        <span class="text-body-md text-text-5">alejandro-portfolio</span>
      </div>

      <!-- Right: page links -->
      <ul class="flex items-center gap-6 list-none m-0 p-0" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[
                "text-body-md transition-colors duration-100",
                "focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-primary-500 focus-visible:ring-offset-1 focus-visible:ring-offset-surface",
                isActive(link.href)
                  ? "bg-primary-500 text-surface px-2 py-0.5"
                  : "text-text-5 hover:text-text-3",
              ]}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

    </nav>
  </div>
</header>
