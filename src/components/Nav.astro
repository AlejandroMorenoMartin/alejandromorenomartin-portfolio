---
import type { Lang } from "@/i18n/utils";
import pkg from "../../package.json";
import Btn from "@/components/Btn.astro";

interface Props {
  lang: Lang;
}

const { lang }   = Astro.props;
const version    = `V.${pkg.version}`;
const pathname   = Astro.url.pathname;

const navLinks = [
  { href: "/",            label: "/root" },
  { href: "/proyectos",   label: "/work" },
  { href: "/sobre-mi",    label: "/info" },
  { href: "/trayectoria", label: "/path" },
  { href: "/ctrl",        label: "/ctrl" },
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/" || pathname === "";
  return pathname === href || pathname === href + "/";
}
---

<header
  id="nav"
  class="fixed top-0 inset-x-0 z-50 bg-surface border-b border-[var(--color-border-subtle)]"
  style="background-image: none;"
  aria-label="Main navigation"
>
  <div style="max-width:1024px;margin-inline:auto;">
    <nav class="flex items-center justify-between h-12">

      <!-- Left: ASCII logo -->
      <span class="ascii-logo font-body">/alejandro-portfolio</span>

      <!-- Right: page links -->
      <ul class="flex items-center gap-2 list-none m-0 p-0" role="list">
        {navLinks.map(link => (
          <li>
            <Btn
              href={link.href}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              {link.label}
            </Btn>
          </li>
        ))}
      </ul>

    </nav>

  </div>
<style>
  .ascii-logo {
    font-size:      var(--fs-label-sm);
    color:          var(--color-text-4);
    letter-spacing: 0;
  }

</style>
</header>
