---
import type { Lang } from "@/i18n/utils";
import { useTranslations } from "@/i18n/utils";
import pkg from "../../package.json";
import Btn from "@/components/Btn.astro";
import LangSwitcher from "@/components/LangSwitcher.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t        = useTranslations(lang);
const pathname = Astro.url.pathname;

const navLinks = lang === "en"
  ? [
      { href: "/en",       label: "/root", mobile: true  },
      { href: "/en/work",  label: "/work", mobile: true  },
      { href: "/en/about", label: "/info", mobile: true  },
      { href: "/en/path",  label: "/path", mobile: true  },
      { href: "/ctrl",     label: "/ctrl", mobile: false },
    ]
  : [
      { href: "/",            label: "/root", mobile: true  },
      { href: "/work", label: "/work", mobile: true  },
      { href: "/info", label: "/info", mobile: true  },
      { href: "/path", label: "/path", mobile: true  },
      { href: "/ctrl",        label: "/ctrl", mobile: false },
    ];

const alternatePath = (() => {
  if (lang === "es") {
    const map: Record<string, string> = {
      "/":      "/en",
      "/work":  "/en/work",
      "/info":  "/en/about",
      "/path":  "/en/path",
    };
    if (pathname.startsWith("/work/")) return `/en${pathname}`;
    return map[pathname] ?? "/en";
  } else {
    const map: Record<string, string> = {
      "/en":       "/",
      "/en/work":  "/work",
      "/en/about": "/info",
      "/en/path":  "/path",
    };
    if (pathname.startsWith("/en/work/")) return pathname.replace("/en", "");
    return map[pathname] ?? "/";
  }
})();

function isActive(href: string): boolean {
  if (href === "/" || href === "/en") return pathname === href || pathname === href + "/";
  if (href === "/work") return pathname === href || pathname.startsWith("/work/");
  if (href === "/en/work")   return pathname === href || pathname.startsWith("/en/work/");
  return pathname === href || pathname === href + "/";
}
---

<header
  id="nav"
  class="fixed top-0 inset-x-0 z-50 bg-surface border-b border-[var(--color-border-subtle)]"
  style="background-image: none;"
  aria-label="Main navigation"
>
  <div class="px-5 md:px-0 container-wide">
    <nav class="flex items-center justify-between py-4">

      <!-- Left: ASCII logo -->
      <span class="ascii-logo font-body">/alejandro-portfolio</span>

      <!-- Right: desktop links -->
      <ul class="hidden md:flex items-center gap-2 list-none m-0 p-0" role="list">
        {navLinks.map(link => (
          <li>
            <Btn
              href={link.href}
              aria-current={isActive(link.href) ? "page" : undefined}
            >
              {link.label}
            </Btn>
          </li>
        ))}
        <li class="ml-4">
          <LangSwitcher lang={lang} alternatePath={alternatePath} />
        </li>
      </ul>

      <!-- Right: mobile hamburger -->
      <button
        id="nav-mobile-btn"
        class="md:hidden flex flex-col justify-center items-center gap-[5px] w-9 h-9 border-[0.5px] border-[var(--color-border-subtle)] hover:bg-[var(--color-btn-hover-subtle)] transition-colors duration-fast focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500/40"
        aria-label={t.nav.openMenu}
        data-label-open={t.nav.openMenu}
        data-label-close={t.nav.closeMenu}
        aria-expanded="false"
        aria-controls="nav-mobile-menu"
      >
        <span class="h-bar"></span>
        <span class="h-bar"></span>
        <span class="h-bar"></span>
      </button>

    </nav>
  </div>
</header>

<!-- Mobile menu — aparece bajo el nav, cubre el resto de la pantalla -->
<div
  id="nav-mobile-menu"
  class="fixed top-12 inset-x-0 bottom-0 z-40 bg-[var(--color-surface)] flex flex-col md:hidden opacity-0 pointer-events-none transition-opacity duration-normal"
  style="background-image: none;"
  aria-hidden="true"
>
  <nav class="flex-1 px-5 pt-8 overflow-y-auto">
    <ul class="flex flex-col list-none m-0 p-0" role="list">
      {navLinks.filter(l => l.mobile).map(link => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link block py-5 font-display text-display-md font-bold"
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="py-5 border-b border-[var(--color-border-subtle)]">
        <LangSwitcher lang={lang} alternatePath={alternatePath} />
      </li>
    </ul>
  </nav>
</div>

<style>
  .ascii-logo {
    font-size:      var(--fs-label-sm);
    color:          var(--color-text-4);
    letter-spacing: 0;
  }

  /* Mobile nav links */
  .mobile-nav-link {
    color:         var(--color-text-4);
    border-bottom: 0.5px solid var(--color-border-subtle);
    transition:    color 100ms ease, border-color 100ms ease;
  }
  .mobile-nav-link:hover {
    color: var(--color-text-1);
  }
  .mobile-nav-link[aria-current="page"] {
    color: var(--color-primary);
  }
  .mobile-nav-link:focus-visible {
    outline:      2px solid #E4A711;
    outline-offset: 3px;
  }

  /* Hamburger bars — idénticas */
  .h-bar {
    display:    block;
    width:      18px;
    height:     1px;
    background: var(--color-text-4);
    transition: transform 200ms ease, opacity 200ms ease;
    transform-origin: center;
  }

  /* Hamburger → X animation */
  #nav-mobile-btn[aria-expanded="true"] .h-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  #nav-mobile-btn[aria-expanded="true"] .h-bar:nth-child(2) {
    opacity: 0;
  }
  #nav-mobile-btn[aria-expanded="true"] .h-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
</style>

<script>
  // AbortController cancela listeners anteriores en cada navegación (View Transitions)
  let navController: AbortController | null = null;

  function initMobileNav() {
    navController?.abort();
    navController = new AbortController();
    const { signal } = navController;

    const btn  = document.getElementById("nav-mobile-btn") as HTMLButtonElement | null;
    const menu = document.getElementById("nav-mobile-menu");
    if (!btn || !menu) return;

    const labelOpen  = btn.dataset.labelOpen  ?? "Open menu";
    const labelClose = btn.dataset.labelClose ?? "Close menu";

    function openMenu() {
      btn.setAttribute("aria-expanded", "true");
      btn.setAttribute("aria-label", labelClose);
      menu.classList.remove("opacity-0", "pointer-events-none");
      menu.classList.add("opacity-100");
      menu.setAttribute("aria-hidden", "false");
    }

    function closeMenu() {
      btn.setAttribute("aria-expanded", "false");
      btn.setAttribute("aria-label", labelOpen);
      menu.classList.add("opacity-0", "pointer-events-none");
      menu.classList.remove("opacity-100");
      menu.setAttribute("aria-hidden", "true");
    }

    btn.addEventListener("click", () => {
      btn.getAttribute("aria-expanded") === "true" ? closeMenu() : openMenu();
    }, { signal });

    menu.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", closeMenu, { signal });
    });

    // Cerrar menú al navegar (View Transitions)
    document.addEventListener("astro:before-preparation", closeMenu, { signal });
  }

  initMobileNav();
  document.addEventListener("astro:page-load", initMobileNav);
</script>
