---
import type { Lang } from "@/i18n/utils";
import { useTranslations, getLocalizedPath, getAlternateLang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t         = useTranslations(lang);
const altLang   = getAlternateLang(lang);
const altPath   = lang === "es" ? "/en" : "/";

const links = [
  { href: "#about",      label: t.nav.about },
  { href: "#craft",      label: t.nav.craft },
  { href: "#work",       label: t.nav.work },
  { href: "#experience", label: t.nav.experience },
  { href: "#contact",    label: t.nav.contact },
];
---

<header
  id="nav"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-normal"
  aria-label="Main navigation"
>
  <div class="container-wide section-padding py-0">
    <nav class="flex items-center justify-between h-16">
      <!-- Logo / Name -->
      <a
        href={getLocalizedPath(lang)}
        class="font-display font-semibold text-label-lg text-text-1 hover:text-primary-500 transition-colors duration-fast focus-visible:outline-none"
        aria-label="Inicio"
      >
        AM
      </a>

      <!-- Links — desktop -->
      <ul class="hidden md:flex items-center gap-6" role="list">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-label-sm text-text-4 hover:text-text-1 transition-colors duration-fast focus-visible:outline-none relative group"
            >
              {link.label}
              <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-primary-500 transition-all duration-fast group-hover:w-full" />
            </a>
          </li>
        ))}
      </ul>

      <!-- Right side: lang + theme -->
      <div class="flex items-center gap-3">
        <!-- Language switch -->
        <a
          href={altPath}
          class="text-label-sm text-text-5 hover:text-text-1 transition-colors duration-fast px-2 py-1 rounded-md border border-border hover:border-border-strong"
          aria-label={`Switch to ${t.nav.langSwitch}`}
        >
          {t.nav.langSwitch}
        </a>

        <!-- Theme toggle -->
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle theme"
          class="w-9 h-9 rounded-md border border-border hover:border-border-strong flex items-center justify-center text-text-4 hover:text-text-1 transition-all duration-fast active:scale-95"
        >
          <span id="icon-light" class="hidden">
            <!-- Sun -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </span>
          <span id="icon-dark">
            <!-- Moon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </span>
        </button>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          type="button"
          aria-label="Toggle menu"
          aria-expanded="false"
          class="md:hidden w-9 h-9 rounded-md border border-border hover:border-border-strong flex items-center justify-center text-text-4 hover:text-text-1 transition-all duration-fast"
        >
          <svg id="icon-menu" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6"  x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="icon-close" class="hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-border bg-surface"
  >
    <ul class="container-wide section-padding py-4 flex flex-col gap-4" role="list">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-body-md text-text-3 hover:text-text-1 transition-colors duration-fast block py-1"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  // ─── Scroll behaviour ──────────────────────────────────────
  const nav = document.getElementById("nav")!;
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      nav.classList.add("bg-surface/90", "backdrop-blur-sm", "border-b", "border-border");
    } else {
      nav.classList.remove("bg-surface/90", "backdrop-blur-sm", "border-b", "border-border");
    }
  }, { passive: true });

  // ─── Theme toggle ──────────────────────────────────────────
  const html        = document.documentElement;
  const iconLight   = document.getElementById("icon-light")!;
  const iconDark    = document.getElementById("icon-dark")!;
  const themeBtn    = document.getElementById("theme-toggle")!;

  function applyTheme(theme: string) {
    html.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);
    if (theme === "dark") {
      iconLight.classList.remove("hidden");
      iconDark.classList.add("hidden");
    } else {
      iconLight.classList.add("hidden");
      iconDark.classList.remove("hidden");
    }
  }

  const savedTheme = localStorage.getItem("theme") ?? "dark";
  applyTheme(savedTheme);

  themeBtn.addEventListener("click", () => {
    const current = html.getAttribute("data-theme") ?? "dark";
    applyTheme(current === "dark" ? "light" : "dark");
  });

  // ─── Mobile menu ───────────────────────────────────────────
  const mobileBtn   = document.getElementById("mobile-menu-btn")!;
  const mobileMenu  = document.getElementById("mobile-menu")!;
  const iconMenu    = document.getElementById("icon-menu")!;
  const iconClose   = document.getElementById("icon-close")!;

  mobileBtn.addEventListener("click", () => {
    const isOpen = mobileMenu.classList.toggle("hidden") === false;
    mobileBtn.setAttribute("aria-expanded", String(isOpen));
    iconMenu.classList.toggle("hidden", isOpen);
    iconClose.classList.toggle("hidden", !isOpen);
  });

  // Close on link click
  mobileMenu.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
      mobileBtn.setAttribute("aria-expanded", "false");
      iconMenu.classList.remove("hidden");
      iconClose.classList.add("hidden");
    });
  });
</script>
