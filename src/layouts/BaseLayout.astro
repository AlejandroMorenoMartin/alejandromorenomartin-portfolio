---
import { ViewTransitions } from "astro:transitions";
import Analytics from "@vercel/analytics/astro";
import "@/styles/global.css";
import type { Lang } from "@/i18n/utils";

interface Props {
  title:       string;
  description: string;
  lang:        Lang;
  ogImage?:    string;
  canonicalURL?: string;
  alternateURL?: string;
  alternateLang?: Lang;
}

const {
  title,
  description,
  lang,
  ogImage       = "/og-es.png",
  canonicalURL  = Astro.url.href,
  alternateURL,
  alternateLang,
} = Astro.props;

const siteURL = "https://alejandromorenomartin.com";

const jsonLd = {
  "@context":  "https://schema.org",
  "@type":     "Person",
  name:        "Alejandro Moreno Martín",
  jobTitle:    "Product Designer",
  url:         siteURL,
  sameAs: [
    "https://www.linkedin.com/in/alejandromorenoproductdesigner/",
    "https://x.com/AMor3noM",
    "https://github.com/AlejandroMorenoMartin",
  ],
  knowsLanguage: ["es", "en"],
};
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang -->
    {alternateURL && alternateLang && (
      <link rel="alternate" hreflang={alternateLang} href={alternateURL} />
    )}
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={siteURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={`${siteURL}${ogImage}`} />
    <meta property="og:locale"      content={lang === "es" ? "es_ES" : "en_US"} />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={`${siteURL}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/browser-icon.png" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <ViewTransitions />

    <!-- Language redirect (only from root "/") -->
    <script is:inline define:vars={{ lang }}>
      (function () {
        if (lang !== "es") return;
        if (localStorage.getItem("lang-redirected")) return;
        localStorage.setItem("lang-redirected", "1");
        const browserLang = (navigator.language || "").toLowerCase();
        if (!browserLang.startsWith("es")) {
          window.location.replace("/en");
        }
      })();
    </script>
  </head>
  <body>
    <div class="scroll-fade scroll-fade--top"    aria-hidden="true"></div>
    <div class="scroll-fade scroll-fade--bottom" aria-hidden="true"></div>
    <slot />
    <Analytics />

    <!-- Page title typewriter + content reveal -->
    <style>
      .scroll-fade {
        position:       fixed;
        inset-inline:   0;
        height:         6rem;
        pointer-events: none;
        z-index:        45;
      }
      .scroll-fade--top {
        top:        3rem;
        background: linear-gradient(to bottom, var(--color-surface), transparent);
      }
      .scroll-fade--bottom {
        bottom:     3rem;
        background: linear-gradient(to top, var(--color-surface), transparent);
      }
    </style>

    <script is:inline>
      // Título estático — sin animación
      function setPageTitle() {
        var titleEl = document.getElementById("page-title");
        if (titleEl) {
          titleEl.textContent = titleEl.getAttribute("data-title") || "";
        }
      }
      setPageTitle();
      document.addEventListener("astro:page-load", setPageTitle);

      // Scroll a top instantáneo tras la transición
      document.addEventListener("astro:after-swap", function () {
        var main = document.getElementById("main-scroll");
        if (main) main.scrollTop = 0;
      });
    </script>


    <!-- KeyboardManager — desktop only -->
    <script>
      (function () {
        const pages = ["/", "/proyectos", "/sobre-mi", "/trayectoria", "/ctrl"];

        function currentPath(): string {
          return window.location.pathname.replace(/\/$/, "") || "/";
        }

        function pageIndex(): number {
          const idx = pages.indexOf(currentPath());
          return idx === -1 ? 0 : idx;
        }

        function isTyping(e: KeyboardEvent): boolean {
          const t = e.target as HTMLElement;
          return t.tagName === "INPUT" || t.tagName === "TEXTAREA" || t.isContentEditable;
        }

        window.addEventListener("keydown", (e: KeyboardEvent) => {
          if (isTyping(e)) return;
          if (e.metaKey || e.ctrlKey || e.altKey) return;
          switch (e.key) {
            case "ArrowRight": {
              e.preventDefault();
              const next = pages[pageIndex() + 1];
              if (next) window.location.href = next;
              break;
            }
            case "ArrowLeft": {
              e.preventDefault();
              const prev = pages[pageIndex() - 1];
              if (prev) window.location.href = prev;
              break;
            }
            case "ArrowDown": {
              const main = document.getElementById("main-scroll");
              if (main?.dataset.noScroll !== undefined) break;
              e.preventDefault();
              (main ?? window).scrollBy({ top: 120, behavior: "smooth" });
              break;
            }
            case "ArrowUp": {
              const main = document.getElementById("main-scroll");
              if (main?.dataset.noScroll !== undefined) break;
              e.preventDefault();
              (main ?? window).scrollBy({ top: -120, behavior: "smooth" });
              break;
            }
            case "Backspace": {
              e.preventDefault();
              history.back();
              break;
            }
            case "Escape": {
              e.preventDefault();
              window.location.href = "/";
              break;
            }
          }
        });
      })();
    </script>
  </body>
</html>
